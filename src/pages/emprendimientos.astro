---
import Layout from '../layouts/Layout.astro'
import { CONTACT } from '../data/site'

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Emprendimientos', url: '/emprendimientos' },
]
---

<Layout
  title="Emprendimientos · Coldwell Banker Beyker"
  description="Comercialización de proyectos en pozo y construcción. Alianzas con desarrolladores, fideicomisos y constructoras."
  breadcrumbs={breadcrumbs}
>
  <section class="border-b border-border bg-elevated/30">
    <div class="container-app py-16 lg:py-20">
      <div class="max-w-3xl">
        <div class="section-eyebrow mb-3">Inversión inmobiliaria</div>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tightest mb-6">
          Emprendimientos<br />
          <span class="text-accent">en pozo y construcción.</span>
        </h1>
        <p class="text-lg text-muted leading-relaxed">
          Trabajamos con desarrolladores, fideicomisos y constructoras para comercializar unidades en proyectos
          residenciales y comerciales en Buenos Aires.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-app">
      <div class="bg-elevated border border-border rounded-3xl p-10 lg:p-16 text-center">
        <div class="w-16 h-16 mx-auto rounded-full bg-accent/10 text-accent flex items-center justify-center mb-6">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 21h18M5 21V5a2 2 0 012-2h10a2 2 0 012 2v16M9 8h.01M9 12h.01M9 16h.01M15 8h.01M15 12h.01M15 16h.01"/>
          </svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold mb-4">Próximamente</h2>
        <p class="text-muted max-w-xl mx-auto leading-relaxed mb-8">
          Estamos preparando el catálogo completo de emprendimientos. Si querés conocer las oportunidades disponibles
          hoy, escribinos directamente.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href={CONTACT.whatsapp_link} target="_blank" rel="noopener" class="btn-primary">
            Consultar por WhatsApp
          </a>
          <a href="/contacto" class="btn-secondary">Formulario de contacto</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
