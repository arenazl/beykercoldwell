---
import Layout from '../layouts/Layout.astro'
import { PROPERTIES, formatPriceUSD } from '../data/properties'

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Comparador IA', url: '/comparar' },
]

// Sample inicial: 12 propiedades destacadas para que el usuario elija.
const sample = PROPERTIES.slice(0, 36)
---

<Layout
  title="Comparador IA · Compará hasta 3 propiedades · Coldwell Banker Beyker"
  description="Elegí 2 o 3 propiedades y la IA te arma una tabla comparativa con veredicto, perfil ideal y riesgos a chequear."
  breadcrumbs={breadcrumbs}
>
  <section class="border-b border-border bg-elevated/30">
    <div class="container-app py-12 lg:py-16">
      <div class="max-w-3xl">
        <div class="section-eyebrow mb-3">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
          </svg>
          Comparador IA
        </div>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tightest leading-[1.05] mb-5">
          ¿Cuál te conviene?<br />
          <span class="text-accent">La IA decide por vos.</span>
        </h1>
        <p class="text-lg text-muted leading-relaxed">
          Marcá hasta 3 propiedades y la IA arma tabla comparativa, veredicto y para qué perfil
          es cada una.
        </p>
      </div>
    </div>
  </section>

  <section class="container-app py-12">
    <div class="max-w-6xl mx-auto">
      <div class="sticky top-20 z-10 mb-8 p-4 rounded-2xl glass-strong flex items-center justify-between gap-4">
        <div class="text-sm">
          <span class="text-muted">Seleccionadas:</span>
          <span id="count" class="font-bold text-accent">0</span>
          <span class="text-muted"> / 3</span>
        </div>
        <button id="compare-btn" type="button" disabled class="btn-primary disabled:opacity-40 disabled:cursor-not-allowed">
          <span id="compare-label">Comparar con IA</span>
        </button>
      </div>

      <div id="error" class="hidden mb-6 p-4 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm"></div>

      <div id="result" class="hidden mb-12 space-y-6"></div>

      <div>
        <h2 class="text-xl font-bold mb-5">Seleccioná hasta 3 propiedades</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {sample.map((p) => (
            <label class="cmp-tile cursor-pointer block">
              <input type="checkbox" value={p.id} class="sr-only cmp-check" />
              <div class="property-card group !transition-all">
                <div class="aspect-[4/3] overflow-hidden bg-border/30 relative">
                  {p.image && <img src={p.image} alt="" loading="lazy" class="absolute inset-0 w-full h-full object-cover" />}
                  <div class="cmp-overlay absolute inset-0 bg-accent/0 transition-colors flex items-center justify-center">
                    <span class="cmp-mark hidden w-10 h-10 rounded-full bg-accent text-bg items-center justify-center font-bold text-lg">✓</span>
                  </div>
                </div>
                <div class="p-3">
                  <div class="text-xs font-bold line-clamp-2 leading-snug">{p.title}</div>
                  <div class="text-[10px] text-muted truncate mt-1">📍 {p.location}</div>
                  <div class="text-sm font-bold text-accent mt-1">{formatPriceUSD(p.priceValue, p.priceCurrency)}</div>
                </div>
              </div>
            </label>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .cmp-check:checked ~ .property-card {
    @apply border-accent shadow-lg shadow-accent/20;
  }
  .cmp-check:checked ~ .property-card .cmp-overlay {
    background-color: rgb(var(--accent) / 0.25);
  }
  .cmp-check:checked ~ .property-card .cmp-mark {
    @apply flex;
  }
</style>

<script>
  import { startThinking } from '../lib/thinking-rotator'

  const checks = document.querySelectorAll<HTMLInputElement>('.cmp-check')
  const counter = document.getElementById('count') as HTMLSpanElement
  const btn = document.getElementById('compare-btn') as HTMLButtonElement
  const lbl = document.getElementById('compare-label') as HTMLSpanElement
  const errorBox = document.getElementById('error') as HTMLDivElement
  const result = document.getElementById('result') as HTMLDivElement

  function escapeHtml(s: string): string {
    const d = document.createElement('div')
    d.textContent = s
    return d.innerHTML
  }
  function selected(): string[] {
    return Array.from(checks).filter((c) => c.checked).map((c) => c.value)
  }

  // Pre-select via ?ids=a,b
  const params = new URLSearchParams(location.search)
  const initial = (params.get('ids') || '').split(',').filter(Boolean)
  initial.forEach((id) => {
    const c = Array.from(checks).find((x) => x.value === id)
    if (c) c.checked = true
  })

  function updateState() {
    const ids = selected()
    counter.textContent = String(ids.length)
    btn.disabled = ids.length < 2 || ids.length > 3

    // Limit to 3 — disable unchecked when 3 reached.
    const max = ids.length >= 3
    checks.forEach((c) => {
      if (!c.checked) c.disabled = max
    })
  }
  checks.forEach((c) => c.addEventListener('change', updateState))
  updateState()

  btn.addEventListener('click', async () => {
    const ids = selected()
    if (ids.length < 2 || ids.length > 3) return
    errorBox.classList.add('hidden')
    result.classList.add('hidden')
    btn.disabled = true
    const stopThinking = startThinking(lbl, {
      messages: [
        'Comparando propiedades',
        'Pesando pros y contras',
        'Eligiendo la mejor opción',
        'Casi listo',
      ],
    })

    try {
      const res = await fetch('/api/comparar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids }),
      })
      const data = await res.json()
      if (!res.ok) {
        errorBox.textContent = data.error || 'Error desconocido'
        errorBox.classList.remove('hidden')
        return
      }

      const props = data.properties || []
      const headerCells = props.map((p: any) =>
        `<th class="px-3 py-3 text-left text-xs font-semibold text-text">
          <div class="line-clamp-2">${escapeHtml(p.title)}</div>
          <div class="text-[10px] text-muted font-normal mt-1">${escapeHtml(p.location.split(',')[0] || '')}</div>
        </th>`
      ).join('')

      const bodyRows = (data.tabla || []).map((row: any) => {
        const cells = props.map((p: any) =>
          `<td class="px-3 py-3 text-sm text-text/85 border-t border-border">${escapeHtml(String(row[p.id] ?? '—'))}</td>`
        ).join('')
        return `<tr><td class="px-3 py-3 text-xs text-muted font-semibold border-t border-border">${escapeHtml(row.criterio || '')}</td>${cells}</tr>`
      }).join('')

      const winner = props.find((p: any) => p.id === data.ganadora?.propertyId)
      const perfilCards = props.map((p: any) => `
        <div class="card-static">
          <div class="text-xs text-muted uppercase tracking-wider mb-1 line-clamp-1">${escapeHtml(p.title)}</div>
          <div class="text-sm text-text/90 leading-relaxed">${escapeHtml((data.paraQuienCadaUna || {})[p.id] || '—')}</div>
        </div>
      `).join('')

      result.innerHTML = `
        ${winner ? `
          <div class="card-static border-accent/40 bg-accent/5">
            <div class="flex items-center gap-3 mb-2">
              <span class="px-3 py-1 rounded-full bg-accent text-bg text-xs font-bold">⭐ La elegida</span>
              <h3 class="text-base font-bold line-clamp-1">${escapeHtml(winner.title)}</h3>
            </div>
            <p class="text-sm text-text/90 leading-relaxed">${escapeHtml(data.ganadora?.razon || '')}</p>
          </div>
        ` : ''}

        <div class="card-static overflow-x-auto">
          <h3 class="text-base font-bold mb-3">Comparación</h3>
          <table class="w-full min-w-[640px]">
            <thead>
              <tr><th class="px-3 py-3 text-left text-xs font-semibold text-muted">Criterio</th>${headerCells}</tr>
            </thead>
            <tbody>${bodyRows}</tbody>
          </table>
        </div>

        <div>
          <h3 class="text-base font-bold mb-3">Para quién es cada una</h3>
          <div class="grid gap-3" style="grid-template-columns: repeat(${props.length}, minmax(0, 1fr));">${perfilCards}</div>
        </div>

        <div class="card-static border-amber-500/30 bg-amber-500/5">
          <h3 class="text-sm font-semibold text-amber-400 mb-2">A chequear antes de decidir</h3>
          <ul class="text-sm space-y-1.5 text-text/85">${(data.riesgos || []).map((r: string) => `<li class="flex gap-2"><span class="text-amber-400 flex-shrink-0">!</span><span>${escapeHtml(r)}</span></li>`).join('')}</ul>
        </div>
      `
      result.classList.remove('hidden')
      result.scrollIntoView({ behavior: 'smooth', block: 'start' })
    } catch (err) {
      errorBox.textContent = 'Error: ' + String((err as Error).message)
      errorBox.classList.remove('hidden')
    } finally {
      stopThinking()
      btn.disabled = false
      lbl.textContent = 'Comparar con IA'
    }
  })
</script>
