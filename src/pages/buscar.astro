---
import Layout from '../layouts/Layout.astro'
import { CATALOG_META, FILTERS } from '../data/properties'
import SortBar from '../components/SortBar.astro'

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Búsqueda inteligente', url: '/buscar' },
]

const sugerencias = [
  'Departamento 2 ambientes en Palermo hasta USD 200.000 apto crédito',
  'Departamento a estrenar en Capital, 1 dormitorio',
  'Casa con pileta en zona norte para vivir, hasta 500k',
  'PH en CABA con patio, máximo 150k, no más de 20 años',
  'Casa quinta para fin de semana cerca de Pilar',
]
---

<Layout
  title="Búsqueda inteligente · Coldwell Banker Beyker"
  description={`Buscá entre ${CATALOG_META.total} propiedades de la red Coldwell Banker Argentina con nuestro asistente. Decinos qué buscás en lenguaje natural.`}
  breadcrumbs={breadcrumbs}
>
  <section class="relative overflow-hidden -mt-16 lg:-mt-20 pt-16 lg:pt-20">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-[rgb(var(--navy))]/40 via-bg to-bg"></div>
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] aspect-square bg-accent/15 blur-[120px] rounded-full animate-float"></div>
    </div>

    <div class="container-app pt-12 lg:pt-20 pb-8">
      <div class="max-w-3xl mx-auto text-center reveal">
        <div class="section-eyebrow mb-5 justify-center">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
          </svg>
          Búsqueda guiada
        </div>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tightest leading-[1.02] mb-6">
          Decime qué buscás.<br />
          <span class="gradient-text-accent">Yo me encargo del resto.</span>
        </h1>
        <p class="text-base lg:text-lg text-muted leading-relaxed max-w-2xl mx-auto">
          {CATALOG_META.total.toLocaleString('es-AR')} propiedades de toda la red Coldwell Banker Argentina. Escribí en lenguaje natural — barrio, ambientes, presupuesto, características — y elegimos lo que mejor matchea.
        </p>
      </div>
    </div>
  </section>

  <section class="container-app pb-20">
    <div class="max-w-4xl mx-auto">
      <form id="ai-form" class="glass-strong rounded-3xl shadow-2xl p-2 mb-8 reveal">
        <div class="flex flex-col sm:flex-row gap-2">
          <div class="flex-1 flex items-center gap-3 px-5 py-3 sm:py-1">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent flex-shrink-0">
              <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
            </svg>
            <input
              id="query"
              name="query"
              type="text"
              placeholder="Departamento 2 ambientes en Recoleta hasta 200k apto crédito…"
              class="flex-1 bg-transparent text-text placeholder:text-muted/60 text-base
                     focus:outline-none border-none"
              autocomplete="off"
            />
            <button
              type="button"
              id="mic-btn"
              aria-label="Buscar por voz"
              title="Buscar por voz"
              class="flex-shrink-0 w-10 h-10 rounded-full border border-border text-muted hover:text-accent hover:border-accent/40 transition-all duration-200 active:scale-95 flex items-center justify-center"
            >
              <svg id="mic-icon-idle" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" />
                <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
                <line x1="12" y1="19" x2="12" y2="23" />
                <line x1="8" y1="23" x2="16" y2="23" />
              </svg>
              <svg id="mic-icon-recording" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="hidden text-red-500">
                <rect x="6" y="6" width="12" height="12" rx="2" />
              </svg>
            </button>
          </div>
          <button type="submit" id="ai-submit" class="btn-primary justify-center sm:px-8 sm:py-3.5">
            <span id="ai-submit-label">Buscar</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </button>
        </div>

        <div id="mic-status" class="hidden mt-3 flex items-center gap-2 text-xs">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500/60"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
          </span>
          <span id="mic-status-label" class="text-muted">Escuchando…</span>
          <span class="text-muted/60 ml-auto" id="mic-engine-hint"></span>
        </div>
      </form>

      <details class="group mb-6 reveal reveal-delay-1">
        <summary class="cursor-pointer inline-flex items-center gap-2 text-sm text-muted hover:text-accent transition-colors select-none list-none [&::-webkit-details-marker]:hidden">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform duration-200 group-open:rotate-180">
            <polyline points="6 9 12 15 18 9" />
          </svg>
          <span>Más filtros</span>
          <span class="text-xs text-muted/70">(combos clásicos)</span>
        </summary>

        <form id="classic-form" class="mt-4 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 p-5 rounded-2xl glass">
          <label class="flex flex-col gap-1.5">
            <span class="text-xs text-muted">Operación</span>
            <select name="operacion" class="bg-elevated border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent/60">
              <option value="">Cualquiera</option>
              {FILTERS.operaciones.map((op) => (
                <option value={op}>{op.charAt(0).toUpperCase() + op.slice(1)}</option>
              ))}
            </select>
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-xs text-muted">Tipo</span>
            <select name="type" class="bg-elevated border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent/60">
              <option value="">Cualquiera</option>
              {FILTERS.tipos.map((t) => (
                <option value={t}>{t}</option>
              ))}
            </select>
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-xs text-muted">Ambientes</span>
            <select name="bedrooms" class="bg-elevated border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent/60">
              <option value="">Cualquiera</option>
              <option value="1">1 ambiente</option>
              <option value="2">2 ambientes</option>
              <option value="3">3 ambientes</option>
              <option value="4+">4+ ambientes</option>
            </select>
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-xs text-muted">Precio mín. (USD)</span>
            <input type="number" name="minPriceUSD" placeholder="0" min="0" class="bg-elevated border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent/60" />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-xs text-muted">Precio máx. (USD)</span>
            <input type="number" name="maxPriceUSD" placeholder="Sin límite" min="0" class="bg-elevated border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent/60" />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-xs text-muted">Superficie (m²)</span>
            <div class="flex gap-2">
              <input type="number" name="minSurfaceM2" placeholder="Min" min="0" class="flex-1 min-w-0 bg-elevated border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent/60" />
              <input type="number" name="maxSurfaceM2" placeholder="Max" min="0" class="flex-1 min-w-0 bg-elevated border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent/60" />
            </div>
          </label>

          <label class="flex items-center gap-2 col-span-full md:col-span-1 self-end pb-2">
            <input type="checkbox" name="aEstrenar" class="w-4 h-4 accent-accent" />
            <span class="text-sm text-text">Solo a estrenar / en pozo</span>
          </label>

          <div class="col-span-full flex justify-end gap-2 pt-3 border-t border-border/50">
            <button type="reset" class="px-4 py-2 rounded-lg text-sm border border-border text-muted hover:text-text hover:border-text/50 transition-all duration-200 active:scale-95">Limpiar</button>
            <button type="submit" class="btn-primary text-sm sm:px-5 sm:py-2.5">Aplicar filtros</button>
          </div>
        </form>
      </details>

      <div class="flex flex-wrap items-center gap-2 mb-10 reveal reveal-delay-1">
        <span class="text-xs text-muted">Probá:</span>
        {sugerencias.map((s) => (
          <button
            type="button"
            data-suggestion={s}
            class="suggestion px-3.5 py-1.5 rounded-full text-xs border border-border text-muted hover:text-accent hover:border-accent/40 hover:bg-accent/5 transition-all"
          >
            {s}
          </button>
        ))}
      </div>

      <div id="ai-status" class="hidden mb-8 p-5 rounded-2xl glass scroll-mt-32">
        <div class="flex items-start gap-3">
          <div class="w-9 h-9 rounded-xl bg-accent/15 text-accent flex items-center justify-center flex-shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <div id="ai-summary" class="text-text font-semibold mb-1"></div>
            <div id="ai-meta" class="text-xs text-muted leading-relaxed"></div>
            <div id="ai-followup" class="hidden mt-3 text-sm text-accent border-t border-border/50 pt-3"></div>
            <div id="ai-followup-chips" class="hidden mt-2 flex flex-wrap gap-2"></div>
          </div>
        </div>
      </div>

      <div id="ai-error" class="hidden mb-6 p-4 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm"></div>

      <div id="ai-suggest" class="hidden mb-6 p-6 rounded-2xl glass scroll-mt-32">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-accent/15 text-accent flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 8v4M12 16h.01" />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <h3 id="ai-suggest-title" class="font-bold text-text mb-1"></h3>
            <p id="ai-suggest-message" class="text-sm text-muted leading-relaxed mb-3"></p>
            <div id="ai-suggest-chips" class="flex flex-wrap gap-2"></div>
          </div>
        </div>
      </div>

      <div id="ai-out-of-scope" class="hidden mb-6 p-6 rounded-2xl bg-amber-500/10 border border-amber-500/30 scroll-mt-32">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-amber-500/20 text-amber-600 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M12 9v4M12 17h.01M3 21h18L12 3 3 21z" />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-text mb-1">Esa búsqueda cae fuera del catálogo</h3>
            <p id="ai-out-of-scope-message" class="text-sm text-text/80 leading-relaxed"></p>
          </div>
        </div>
      </div>

      <div id="ai-active-filters" class="hidden flex flex-wrap items-center gap-2 mb-4">
        <span class="text-xs text-muted mr-1">Filtros aplicados:</span>
      </div>

      <div id="ai-sortbar-wrap" class="hidden mb-6">
        <SortBar target="#ai-results" />
      </div>

      <div id="ai-results" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6"></div>

      <div id="ai-empty" class="hidden text-center py-20 text-muted">
        <div class="text-5xl mb-3 opacity-40">🔍</div>
        <p>Sin resultados para esa búsqueda.</p>
        <p class="text-sm mt-1">Probá relajar algún filtro o describir lo que buscás de otra forma.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { startThinking } from '../lib/thinking-rotator'
  import { setBtnLoading } from '../lib/btn-loading'

  const form = document.getElementById('ai-form') as HTMLFormElement
  const input = document.getElementById('query') as HTMLInputElement
  const submitBtn = document.getElementById('ai-submit') as HTMLButtonElement
  const submitLabel = document.getElementById('ai-submit-label') as HTMLSpanElement
  const status = document.getElementById('ai-status') as HTMLDivElement
  const summary = document.getElementById('ai-summary') as HTMLDivElement
  const meta = document.getElementById('ai-meta') as HTMLDivElement
  const followup = document.getElementById('ai-followup') as HTMLDivElement
  const error = document.getElementById('ai-error') as HTMLDivElement
  const results = document.getElementById('ai-results') as HTMLDivElement
  const empty = document.getElementById('ai-empty') as HTMLDivElement
  const outOfScope = document.getElementById('ai-out-of-scope') as HTMLDivElement
  const outOfScopeMessage = document.getElementById('ai-out-of-scope-message') as HTMLParagraphElement
  const suggest = document.getElementById('ai-suggest') as HTMLDivElement
  const suggestTitle = document.getElementById('ai-suggest-title') as HTMLHeadingElement
  const suggestMessage = document.getElementById('ai-suggest-message') as HTMLParagraphElement
  const suggestChips = document.getElementById('ai-suggest-chips') as HTMLDivElement
  const followupChips = document.getElementById('ai-followup-chips') as HTMLDivElement
  const activeFilters = document.getElementById('ai-active-filters') as HTMLDivElement
  const activeFiltersLabel = activeFilters.firstElementChild as HTMLSpanElement

  type AnyFilters = Record<string, unknown> & { type?: string; location_includes?: string; summary?: string }
  let lastFilters: AnyFilters | null = null

  document.querySelectorAll<HTMLButtonElement>('.suggestion').forEach((btn) => {
    btn.addEventListener('click', () => {
      const s = btn.dataset.suggestion
      if (!s) return
      input.value = s
      form.requestSubmit()
    })
  })

  function fmtPrice(p: number | null, c: string) {
    if (p == null) return 'Consultar'
    return `${c || 'USD'} ${p.toLocaleString('es-AR')}`
  }

  function renderCard(item: any): string {
    const p = item.property
    const hits = (item.hits as string[]).map(
      (h) => `<span class="text-xs px-2 py-0.5 rounded-full bg-accent/10 text-accent border border-accent/20">${h}</span>`
    ).join('')
    const href = p.slug ? `/propiedades/${p.slug}` : '#'
    return `
      <article class="property-card group" data-sort-price="${p.priceValue ?? ''}" data-sort-m2="${p.surfaceM2 ?? ''}" data-sort-bedrooms="${p.bedrooms ?? ''}">
        <a href="${href}" class="block relative aspect-[4/3] overflow-hidden bg-border/30">
          <img src="${p.image}" alt="${p.title.replace(/"/g, '&quot;')}" loading="lazy"
               class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute top-3 left-3 flex flex-wrap gap-2">
            <span class="px-3 py-1 text-xs font-semibold rounded-full bg-accent text-white shadow-lg">
              ${p.operacion ? p.operacion[0].toUpperCase() + p.operacion.slice(1) : 'Consultar'}
            </span>
            <span class="px-3 py-1 text-xs font-semibold rounded-full bg-elevated/90 text-text border border-border backdrop-blur-sm">
              ${p.type || ''}
            </span>
          </div>
        </a>
        <div class="p-5 flex-1 flex flex-col gap-3 min-w-0">
          ${hits ? `<div class="flex flex-wrap gap-1.5">${hits}</div>` : ''}
          <h3 class="text-lg font-bold text-text leading-snug line-clamp-2">${p.title || 'Propiedad'}</h3>
          <p class="text-sm text-muted truncate">📍 ${p.location || '—'}</p>
          <div class="flex items-center gap-4 text-sm text-text/80 pt-2 border-t border-border">
            ${p.bedrooms != null ? `<span>🛏 ${p.bedrooms} dorm.</span>` : ''}
            ${p.bathrooms != null ? `<span>🛁 ${p.bathrooms} baño${p.bathrooms === 1 ? '' : 's'}</span>` : ''}
            ${p.surfaceM2 != null ? `<span>📐 ${p.surfaceM2} m²</span>` : ''}
          </div>
          <div class="flex items-center justify-between pt-3 border-t border-border">
            <div>
              <div class="text-xs text-muted">Precio de ${p.operacion || 'venta'}</div>
              <div class="text-xl font-bold text-accent">${fmtPrice(p.priceValue, p.priceCurrency)}</div>
            </div>
            <a href="${href}" class="text-sm font-semibold text-accent hover:text-accent-hover">
              Ver ficha →
            </a>
          </div>
        </div>
      </article>
    `
  }

  // Autocompletar + autosearch desde ?q= (usado por el mic de la bottom bar mobile).
  const params = new URLSearchParams(window.location.search)
  const initialQ = params.get('q')?.trim()
  if (initialQ) {
    input.value = initialQ
    requestAnimationFrame(() => form.requestSubmit())
  }

  function fmtPriceLabel(usd: number): string {
    if (usd >= 1_000_000) return `USD ${(usd / 1_000_000).toFixed(1)}M`
    if (usd >= 1_000) return `USD ${Math.round(usd / 1_000)}k`
    return `USD ${Math.round(usd)}`
  }

  type Pill = { keys: string[]; label: string; keywordIdx?: number }

  function buildPills(f: AnyFilters): Pill[] {
    const pills: Pill[] = []
    if (f.type) pills.push({ keys: ['type'], label: String(f.type) })
    if (f.location_includes) pills.push({ keys: ['location_includes'], label: '📍 ' + String(f.location_includes) })
    if (f.operacion) {
      const op = String(f.operacion)
      pills.push({ keys: ['operacion'], label: op.charAt(0).toUpperCase() + op.slice(1) })
    }

    const minB = f.minBedrooms as number | undefined
    const maxB = f.maxBedrooms as number | undefined
    if (minB != null || maxB != null) {
      let label = ''
      if (minB != null && maxB != null && minB === maxB) label = `${minB} amb`
      else if (minB != null && maxB == null) label = `${minB}+ amb`
      else if (maxB != null && minB == null) label = `Hasta ${maxB} amb`
      else if (minB != null && maxB != null) label = `${minB}–${maxB} amb`
      if (label) pills.push({ keys: ['minBedrooms', 'maxBedrooms'], label })
    }

    const minP = f.minPriceUSD as number | undefined
    const maxP = f.maxPriceUSD as number | undefined
    if (minP != null || maxP != null) {
      let label = ''
      if (minP != null && maxP != null) label = `${fmtPriceLabel(minP)} – ${fmtPriceLabel(maxP)}`
      else if (minP != null) label = `Más de ${fmtPriceLabel(minP)}`
      else if (maxP != null) label = `Hasta ${fmtPriceLabel(maxP)}`
      if (label) pills.push({ keys: ['minPriceUSD', 'maxPriceUSD'], label })
    }

    const minS = f.minSurfaceM2 as number | undefined
    const maxS = f.maxSurfaceM2 as number | undefined
    if (minS != null || maxS != null) {
      let label = ''
      if (minS != null && maxS != null) label = `${minS}–${maxS} m²`
      else if (minS != null) label = `Más de ${minS} m²`
      else if (maxS != null) label = `Hasta ${maxS} m²`
      if (label) pills.push({ keys: ['minSurfaceM2', 'maxSurfaceM2'], label })
    }

    if (f.aEstrenar) pills.push({ keys: ['aEstrenar'], label: '✨ A estrenar' })
    else if (f.maxAntiguedad != null) pills.push({ keys: ['maxAntiguedad'], label: `≤ ${f.maxAntiguedad} años` })

    if (Array.isArray(f.keywords)) {
      const kws = f.keywords as string[]
      for (let i = 0; i < kws.length; i++) {
        pills.push({ keys: [], label: `“${kws[i]}”`, keywordIdx: i })
      }
    }

    return pills
  }

  function renderActiveFilters(f: AnyFilters) {
    while (activeFilters.children.length > 1) activeFilters.removeChild(activeFilters.lastChild as ChildNode)
    const pills = buildPills(f)
    if (pills.length === 0) {
      activeFilters.classList.add('hidden')
      return
    }
    for (const pill of pills) {
      const btn = document.createElement('button')
      btn.type = 'button'
      btn.title = 'Quitar este filtro'
      btn.className =
        'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs bg-elevated border border-border text-text hover:border-red-400/60 hover:text-red-400 transition-all duration-200 active:scale-95 group'
      btn.innerHTML = `<span>${pill.label}</span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="opacity-50 group-hover:opacity-100"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`
      btn.addEventListener('click', () => {
        const newF: AnyFilters = { ...f }
        for (const k of pill.keys) delete newF[k]
        if (pill.keywordIdx != null && Array.isArray(newF.keywords)) {
          const filtered = (newF.keywords as string[]).filter((_, i) => i !== pill.keywordIdx)
          if (filtered.length === 0) delete newF.keywords
          else newF.keywords = filtered
        }
        delete newF.summary
        runSearch({ filters: newF })
      })
      activeFilters.appendChild(btn)
    }
    activeFilters.classList.remove('hidden')
    activeFiltersLabel.classList.remove('hidden')
  }

  function renderSuggest(originalType: string, location: string | undefined, alternatives: { type: string; count: number }[], baseFilters: AnyFilters) {
    suggestTitle.textContent = `Se encontraron 0 ${originalType.toLowerCase()}${location ? ' en ' + location : ''}.`
    const top = alternatives.slice(0, 4)
    const ctx = location ? `En ${location}` : 'Pero'
    suggestMessage.textContent = `${ctx} sí tenemos otros tipos de propiedad. ¿Querés ver alguno?`
    suggestChips.innerHTML = ''
    for (const alt of top) {
      const btn = document.createElement('button')
      btn.type = 'button'
      btn.className =
        'px-4 py-2 rounded-full text-sm border border-accent/30 bg-accent/5 text-accent hover:bg-accent/15 hover:border-accent/60 transition-all duration-200 active:scale-95'
      btn.innerHTML = `${alt.type} <span class="opacity-70">(${alt.count})</span>`
      btn.addEventListener('click', () => {
        const newSummary = `Te muestro los ${alt.type} en ${location ?? 'el catálogo'}.`
        const newFilters: AnyFilters = { ...baseFilters, type: alt.type, summary: newSummary }
        runSearch({ filters: newFilters })
      })
      suggestChips.appendChild(btn)
    }
    suggest.classList.remove('hidden')
    suggest.scrollIntoView({ behavior: 'smooth', block: 'start' })
  }

  async function runSearch(payload: { query?: string; filters?: AnyFilters }) {
    setBtnLoading(submitBtn, true)
    const stopThinking = startThinking(submitLabel, {
      messages: [
        'Buscando propiedades',
        'Filtrando el catálogo',
        'Estás en el mejor sitio',
        'Procesando tu pedido',
        'Casi listo',
      ],
    })
    error.classList.add('hidden')
    status.classList.add('hidden')
    empty.classList.add('hidden')
    outOfScope.classList.add('hidden')
    suggest.classList.add('hidden')
    followupChips.classList.add('hidden')
    followupChips.innerHTML = ''
    activeFilters.classList.add('hidden')
    while (activeFilters.children.length > 1) activeFilters.removeChild(activeFilters.lastChild as ChildNode)
    results.innerHTML = ''

    try {
      const res = await fetch('/api/ai-search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
      const data = await res.json()

      if (!res.ok) {
        error.textContent = data.error || 'Error desconocido'
        if (data.hint) error.textContent += ` — ${data.hint}`
        error.classList.remove('hidden')
        return
      }

      const f = data.filters
      lastFilters = f

      if (f.out_of_scope) {
        outOfScopeMessage.textContent = f.out_of_scope_message ||
          'No tenemos propiedades en esa zona. Nuestro catálogo es exclusivamente Argentina.'
        outOfScope.classList.remove('hidden')
        outOfScope.scrollIntoView({ behavior: 'smooth', block: 'start' })
        return
      }

      summary.textContent = f.summary || 'Resultados'
      const parts: string[] = []
      if (f.operacion) parts.push(f.operacion)
      if (f.type) parts.push(f.type)
      if (f.location_includes) parts.push(`📍 ${f.location_includes}`)
      if (f.maxPriceUSD) parts.push(`hasta USD ${f.maxPriceUSD.toLocaleString('es-AR')}`)
      if (f.minBedrooms) parts.push(`${f.minBedrooms}+ dorm.`)
      if (f.keywords?.length) parts.push(...f.keywords.map((k: string) => `“${k}”`))
      const total: number = data.total
      const rendered: number = data.rendered ?? data.results.length
      let countText: string
      if (rendered === 0) {
        countText = '0 propiedades encontradas'
      } else if (total > rendered) {
        countText = `${total.toLocaleString('es-AR')} propiedades · mostramos las ${rendered} más relevantes`
      } else {
        countText = `${total} propiedad${total === 1 ? '' : 'es'} encontrada${total === 1 ? '' : 's'}`
      }
      meta.textContent = countText + (parts.length ? ' · ' + parts.join(' · ') : '')
      // Próxima dimensión sugerida: si el endpoint mandó `missing`, su pregunta
      // pisa al follow_up libre del LLM (más concreto + accionable).
      const missing = data.missing as { dimension: string; question: string; options: Array<{ label: string; filterPatch: Record<string, unknown>; count: number }> } | undefined
      const followupText = missing?.question || f.follow_up
      if (followupText) {
        followup.textContent = '💬 ' + followupText
        followup.classList.remove('hidden')
      } else {
        followup.classList.add('hidden')
      }

      if (missing?.options?.length) {
        for (const opt of missing.options) {
          const btn = document.createElement('button')
          btn.type = 'button'
          btn.className =
            'px-3.5 py-1.5 rounded-full text-xs border border-accent/40 bg-accent/10 text-accent hover:bg-accent/20 hover:border-accent/70 transition-all duration-200 active:scale-95'
          btn.innerHTML = `${opt.label} <span class="opacity-70">(${opt.count})</span>`
          btn.addEventListener('click', () => {
            const newSummary = `Refinando: ${opt.label.toLowerCase()}.`
            runSearch({ filters: { ...f, ...opt.filterPatch, summary: newSummary } })
          })
          followupChips.appendChild(btn)
        }
        followupChips.classList.remove('hidden')
      }

      status.classList.remove('hidden')
      status.scrollIntoView({ behavior: 'smooth', block: 'start' })

      renderActiveFilters(f)

      const sortbarWrap = document.getElementById('ai-sortbar-wrap') as HTMLDivElement
      if (data.results.length === 0) {
        sortbarWrap.classList.add('hidden')
        if (data.suggest?.reason === 'no_results_for_type' && Array.isArray(data.suggest.alternatives) && data.suggest.alternatives.length) {
          renderSuggest(data.suggest.original_type, f.location_includes, data.suggest.alternatives, f)
        } else {
          empty.classList.remove('hidden')
        }
      } else {
        results.innerHTML = data.results.map(renderCard).join('')
        sortbarWrap.classList.remove('hidden')
        results.dispatchEvent(new CustomEvent('sortbar:reinit'))
      }
    } catch (err) {
      error.textContent = 'No pudimos contactar el servidor: ' + String((err as Error).message)
      error.classList.remove('hidden')
    } finally {
      stopThinking()
      setBtnLoading(submitBtn, false)
      submitLabel.textContent = 'Buscar'
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    const query = input.value.trim()
    if (!query) return
    await runSearch({ query })
  })

  // Form de filtros clásicos: arma `filters` desde los inputs y los manda al
  // mismo endpoint, salteando Gemini (modo `filters` directo).
  const classicForm = document.getElementById('classic-form') as HTMLFormElement | null
  classicForm?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const data = new FormData(classicForm)
    const filters: AnyFilters = {}

    const operacion = String(data.get('operacion') || '').trim()
    if (operacion) filters.operacion = operacion

    const type = String(data.get('type') || '').trim()
    if (type) filters.type = type

    const bedrooms = String(data.get('bedrooms') || '').trim()
    if (bedrooms === '4+') filters.minBedrooms = 4
    else if (bedrooms) {
      const n = Number(bedrooms)
      filters.minBedrooms = n
      filters.maxBedrooms = n
    }

    const minP = Number(data.get('minPriceUSD'))
    if (Number.isFinite(minP) && minP > 0) filters.minPriceUSD = minP
    const maxP = Number(data.get('maxPriceUSD'))
    if (Number.isFinite(maxP) && maxP > 0) filters.maxPriceUSD = maxP

    const minS = Number(data.get('minSurfaceM2'))
    if (Number.isFinite(minS) && minS > 0) filters.minSurfaceM2 = minS
    const maxS = Number(data.get('maxSurfaceM2'))
    if (Number.isFinite(maxS) && maxS > 0) filters.maxSurfaceM2 = maxS

    if (data.get('aEstrenar')) filters.aEstrenar = true

    filters.summary = 'Filtros aplicados manualmente.'
    await runSearch({ filters })
  })

  // ======================
  // Búsqueda por voz
  // ======================
  const micBtn = document.getElementById('mic-btn') as HTMLButtonElement
  const micIconIdle = document.getElementById('mic-icon-idle') as HTMLElement
  const micIconRec = document.getElementById('mic-icon-recording') as HTMLElement
  const micStatus = document.getElementById('mic-status') as HTMLDivElement
  const micStatusLabel = document.getElementById('mic-status-label') as HTMLSpanElement
  const micEngineHint = document.getElementById('mic-engine-hint') as HTMLSpanElement

  // Web Speech API no está en los typings DOM por defecto; usamos any local.
  type SpeechRec = {
    lang: string
    interimResults: boolean
    maxAlternatives: number
    continuous: boolean
    onresult: ((e: { resultIndex: number; results: ArrayLike<{ isFinal: boolean; 0: { transcript: string } }> }) => void) | null
    onerror: ((e: { error: string }) => void) | null
    onend: (() => void) | null
    start: () => void
    stop: () => void
  }
  const SpeechRecognitionCtor =
    ((window as unknown) as { SpeechRecognition?: new () => SpeechRec; webkitSpeechRecognition?: new () => SpeechRec })
      .SpeechRecognition ??
    ((window as unknown) as { SpeechRecognition?: new () => SpeechRec; webkitSpeechRecognition?: new () => SpeechRec })
      .webkitSpeechRecognition

  let isRecording = false
  let activeRecognition: SpeechRec | null = null
  let activeRecorder: MediaRecorder | null = null
  let activeStream: MediaStream | null = null

  function setRecordingUI(on: boolean, label = 'Escuchando…') {
    isRecording = on
    micBtn.classList.toggle('border-red-500/50', on)
    micBtn.classList.toggle('bg-red-500/10', on)
    micIconIdle.classList.toggle('hidden', on)
    micIconRec.classList.toggle('hidden', !on)
    micStatus.classList.toggle('hidden', !on)
    micStatusLabel.textContent = label
    micBtn.setAttribute('aria-label', on ? 'Detener grabación' : 'Buscar por voz')
  }

  function stopAll() {
    if (activeRecognition) {
      try { activeRecognition.stop() } catch {}
      activeRecognition = null
    }
    if (activeRecorder && activeRecorder.state !== 'inactive') {
      try { activeRecorder.stop() } catch {}
    }
    if (activeStream) {
      activeStream.getTracks().forEach((t) => t.stop())
      activeStream = null
    }
    setRecordingUI(false)
  }

  function applyTranscript(text: string) {
    if (!text) return
    input.value = text
    form.requestSubmit()
  }

  function showMicError(msg: string) {
    error.textContent = msg
    error.classList.remove('hidden')
  }

  // ----- Camino A: Web Speech API (en navegador) -----
  function startWebSpeech(): boolean {
    if (!SpeechRecognitionCtor) return false
    const rec = new SpeechRecognitionCtor()
    rec.lang = 'es-AR'
    rec.interimResults = true
    rec.maxAlternatives = 1
    rec.continuous = false

    let finalText = ''
    rec.onresult = (e) => {
      let interim = ''
      for (let i = e.resultIndex; i < e.results.length; i++) {
        const r = e.results[i]
        if (r.isFinal) finalText += r[0].transcript
        else interim += r[0].transcript
      }
      micStatusLabel.textContent = finalText || interim || 'Escuchando…'
    }
    rec.onerror = (e) => {
      activeRecognition = null
      setRecordingUI(false)
      if (e.error === 'no-speech') return
      if (e.error === 'not-allowed' || e.error === 'service-not-allowed') {
        showMicError('Permiso de micrófono denegado. Habilitalo en el navegador.')
        return
      }
      // Cualquier otro error: caer al fallback de servidor.
      startMediaRecorder().catch((err) => showMicError('No pudimos grabar audio: ' + String(err)))
    }
    rec.onend = () => {
      activeRecognition = null
      setRecordingUI(false)
      if (finalText.trim()) applyTranscript(finalText.trim())
    }

    activeRecognition = rec
    micEngineHint.textContent = 'voz · navegador'
    setRecordingUI(true, 'Escuchando…')
    rec.start()
    return true
  }

  // ----- Camino B: MediaRecorder + /api/transcribe (Gemini) -----
  async function startMediaRecorder() {
    if (!navigator.mediaDevices?.getUserMedia) {
      showMicError('Tu navegador no soporta grabación de audio.')
      return
    }
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true })
    activeStream = stream

    const mimeCandidates = [
      'audio/webm;codecs=opus',
      'audio/webm',
      'audio/ogg;codecs=opus',
      'audio/mp4',
    ]
    const mime = mimeCandidates.find((m) => MediaRecorder.isTypeSupported(m)) ?? ''
    const recorder = new MediaRecorder(stream, mime ? { mimeType: mime } : undefined)
    activeRecorder = recorder

    const chunks: Blob[] = []
    recorder.addEventListener('dataavailable', (e: BlobEvent) => {
      if (e.data && e.data.size) chunks.push(e.data)
    })
    recorder.addEventListener('stop', async () => {
      stream.getTracks().forEach((t) => t.stop())
      activeStream = null
      activeRecorder = null
      const blob = new Blob(chunks, { type: mime || 'audio/webm' })
      if (blob.size === 0) {
        setRecordingUI(false)
        return
      }
      micStatusLabel.textContent = 'Transcribiendo…'
      try {
        const base64 = await blobToBase64(blob)
        const res = await fetch('/api/transcribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ audio: base64, mimeType: blob.type || 'audio/webm' }),
        })
        const data = await res.json()
        setRecordingUI(false)
        if (!res.ok) {
          showMicError(data.error || 'Error transcribiendo el audio')
          return
        }
        applyTranscript(String(data.text || '').trim())
      } catch (err) {
        setRecordingUI(false)
        showMicError('No pudimos transcribir el audio: ' + String((err as Error).message))
      }
    })

    micEngineHint.textContent = 'voz · servidor'
    setRecordingUI(true, 'Grabando — clic para parar')
    recorder.start()

    // Hard-stop a los 30s para evitar audios eternos.
    setTimeout(() => {
      if (activeRecorder && activeRecorder.state === 'recording') {
        try { activeRecorder.stop() } catch {}
      }
    }, 30_000)
  }

  function blobToBase64(blob: Blob): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader()
      reader.onloadend = () => {
        const result = String(reader.result || '')
        const comma = result.indexOf(',')
        resolve(comma >= 0 ? result.slice(comma + 1) : result)
      }
      reader.onerror = () => reject(reader.error || new Error('FileReader error'))
      reader.readAsDataURL(blob)
    })
  }

  micBtn.addEventListener('click', async () => {
    error.classList.add('hidden')
    if (isRecording) {
      stopAll()
      return
    }
    if (startWebSpeech()) return
    try {
      await startMediaRecorder()
    } catch (err) {
      showMicError('No pudimos iniciar el micrófono: ' + String((err as Error).message))
    }
  })
</script>
