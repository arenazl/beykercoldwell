            <div class="p-3 rounded-xl border border-border text-center bg-elevated">
              <div class="text-[10px] uppercase tracking-wider text-muted mb-1 font-semibold">Mínimo</div>
              <div class="text-sm font-bold">
                <span data-locked-value class="inline-block" style="filter: blur(6px);">${fmtUSD(r.totalPriceUSD.low)}</span>
              </div>
            </div>
            <div class="p-3 rounded-xl border-2 border-accent bg-accent/5 text-center">
              <div class="text-[10px] uppercase tracking-wider text-accent mb-1 font-bold">Típico</div>
              <div class="text-sm font-bold text-accent">
                <span data-locked-value class="inline-block" style="filter: blur(6px);">${fmtUSD(r.totalPriceUSD.typical)}</span>
              </div>
            </div>
            <div class="p-3 rounded-xl border border-border text-center bg-elevated">
              <div class="text-[10px] uppercase tracking-wider text-muted mb-1 font-semibold">Máximo</div>
              <div class="text-sm font-bold">
                <span data-locked-value class="inline-block" style="filter: blur(6px);">${fmtUSD(r.totalPriceUSD.high)}</span>
              </div>
