          <p class="text-[11px] text-muted mt-4 leading-snug">
            Código de seguimiento: <span class="font-mono font-semibold text-text">${code}</span>
          </p>
        </div>
      </div>
    `
  }

  /**
   * Conecta los CTAs del resultado bloqueado:
   *  - Asesor → WhatsApp con mensaje pre-llenado (datos del wizard + código).
   *  - Mail → POST a /api/valuacion-email con todo. Al ok, desbloquea la banda.
   */
  function wireResultCTAs(r: Result, payload: ValuationPayload) {
    const ctaAsesor = document.getElementById('cta-asesor') as HTMLAnchorElement | null
    const ctaEmailToggle = document.getElementById('cta-email-toggle') as HTMLButtonElement | null
    const ctaEmailForm = document.getElementById('cta-email-form') as HTMLFormElement | null
    const ctaEmailInput = document.getElementById('cta-email-input') as HTMLInputElement | null
    const ctaEmailSubmit = document.getElementById('cta-email-submit') as HTMLButtonElement | null
    const ctaEmailFeedback = document.getElementById('cta-email-feedback') as HTMLParagraphElement | null

    const phone = (form.dataset.waPhone || '').replace(/\D+/g, '')
    const codeMatch = result.querySelector('.font-mono')
    const code = codeMatch?.textContent?.trim() ?? ''

    function unlockBands() {
      // Soportamos los dos selectores: el viejo (toda la card borroneada)
      // y el nuevo (sólo los números marcados con data-locked-value).
      result.querySelectorAll<HTMLElement>('[data-locked-content], [data-locked-value]').forEach((el) => {
        el.style.transition = 'filter 0.6s ease-out'
        el.style.filter = 'blur(0px)'
        el.style.pointerEvents = 'auto'
      })
      // Ocultar el badge "Desbloqueá tu valuación" tras desbloquear
      const lockBadge = result.querySelector('.absolute.inset-0.flex.items-center.justify-center.pointer-events-none')
      if (lockBadge && lockBadge.parentElement) {
        ;(lockBadge as HTMLElement).style.transition = 'opacity 0.4s'
        ;(lockBadge as HTMLElement).style.opacity = '0'
        setTimeout(() => (lockBadge as HTMLElement).remove(), 400)
      }
    }

    if (ctaAsesor) {
      const lines = [
        `Hola, soy de la web. Acabo de pedir una cotización (${code}) y querría que me ayuden.`,
        '',
        '— Datos cargados —',
        `Tipo: ${payload.type || 's/d'} (${payload.state || 's/d'})`,
        payload.address ? `Dirección: ${payload.address}` : null,
        payload.surfaceTotalM2 ? `Superficie total: ${payload.surfaceTotalM2} m²` : null,
        payload.surfaceCoveredM2 ? `Cubierta: ${payload.surfaceCoveredM2} m²` : null,
        payload.rooms ? `Ambientes: ${payload.rooms}` : null,
        payload.bedrooms != null ? `Dormitorios: ${payload.bedrooms}` : null,
        payload.bathrooms != null ? `Baños: ${payload.bathrooms}` : null,
        payload.ageYears != null ? `Antigüedad: ${payload.ageYears} años` : null,
        payload.expensesArs ? `Expensas: ARS ${payload.expensesArs.toLocaleString('es-AR')}` : null,
        payload.features.length ? `Características: ${payload.features.join(', ')}` : null,
        '',
        `Banda calculada: ${fmtUSD(r.totalPriceUSD.low)} – ${fmtUSD(r.totalPriceUSD.typical)} – ${fmtUSD(r.totalPriceUSD.high)}`,
      ].filter(Boolean) as string[]
      const text = encodeURIComponent(lines.join('\n'))
      ctaAsesor.href = phone ? `https://wa.me/${phone}?text=${text}` : '#'
      ctaAsesor.target = '_blank'
      ctaAsesor.rel = 'noopener'
      ctaAsesor.addEventListener('click', () => {
        // Cliente eligió WhatsApp → desbloqueamos para que vea su número
        // mientras vuelve a la página.
        setTimeout(unlockBands, 200)
      })
    }

    if (ctaEmailToggle && ctaEmailForm && ctaEmailInput) {
      ctaEmailToggle.addEventListener('click', () => {
        ctaEmailToggle.classList.add('hidden')
        ctaEmailForm.classList.remove('hidden')
        ctaEmailInput.focus()
      })
    }

    if (ctaEmailForm && ctaEmailInput && ctaEmailSubmit && ctaEmailFeedback) {
      ctaEmailForm.addEventListener('submit', async (ev) => {
        ev.preventDefault()
        const email = ctaEmailInput.value.trim()
        if (!email) return
        setBtnLoading(ctaEmailSubmit, true)
        ctaEmailFeedback.classList.add('hidden')
        try {
          const res = await fetch('/api/valuacion-email', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, code, payload, valuation: r }),
          })
          const data = await res.json().catch(() => ({}))
          if (!res.ok) {
            ctaEmailFeedback.textContent = data.error || 'No pudimos enviar el mail. Probá de nuevo.'
            ctaEmailFeedback.className = 'text-xs mt-2 text-red-500'
            ctaEmailFeedback.classList.remove('hidden')
            return
          }
          // Mensaje de éxito GRANDE — la cotización va al mail, no la
          // mostramos in-page. Las bandas siguen borroneadas.
          ctaEmailFeedback.innerHTML =
            '<span class="text-base">📬 ¡Ya tenés tu cotización lista en el correo!</span>' +
            `<br><span class="text-xs text-muted">La enviamos a <strong>${ctaEmailInput.value.trim()}</strong>. Revisá tu bandeja (y spam).</span>`
          ctaEmailFeedback.className = 'mt-3 text-green-600 font-bold text-center'
          ctaEmailFeedback.classList.remove('hidden')
          ctaEmailInput.disabled = true
          ctaEmailSubmit.disabled = true
          // Importante: NO llamamos a unlockBands(). La idea es que el cliente
          // reciba la cotización por mail y no la vea acá in-page.
        } catch (err) {
          ctaEmailFeedback.textContent = 'Sin conexión: ' + String((err as Error).message)
          ctaEmailFeedback.className = 'text-xs mt-2 text-red-500'
          ctaEmailFeedback.classList.remove('hidden')
        } finally {
          setBtnLoading(ctaEmailSubmit, false)
        }
      })
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()

    const features = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="feature"]:checked')).map((i) => i.value)

    const payload: ValuationPayload = {
      type: (document.getElementById('f-type') as HTMLSelectElement).value,
      state: (document.getElementById('f-state') as HTMLSelectElement).value,
      location: str('f-location'),
      street: str('f-street'),
      streetNumber: str('f-street-number'),
      address: str('f-address'),
      lat: num('f-lat'),
      lng: num('f-lng'),
      floor: str('f-floor'),
      unit: str('f-unit'),
      orientation: (document.getElementById('f-orientation') as HTMLSelectElement).value || undefined,
      surfaceTotalM2: num('f-surface-total'),
      surfaceCoveredM2: num('f-surface-covered'),
      rooms: num('f-rooms'),
      bedrooms: num('f-bedrooms'),
      bathrooms: num('f-bathrooms'),
      ageYears: num('f-age'),
      expensesArs: unmaskMoney((document.getElementById('f-expenses') as HTMLInputElement | null)?.value) ?? undefined,
      features,
      notes: str('f-notes'),
    }

    if (!payload.location) {
      errorBox.textContent = 'Necesitamos una dirección verificada para valuar.'
      errorBox.classList.remove('hidden')
      return
    }
    if (!payload.surfaceTotalM2) {
      errorBox.textContent = 'Necesitamos la superficie total en m².'
      errorBox.classList.remove('hidden')
      return
    }

    setBtnLoading(submitBtn, true)
    submitLabel.textContent = 'Analizando…'
    empty.classList.add('hidden')
    errorBox.classList.add('hidden')
    result.classList.add('hidden')
    loading.classList.remove('hidden')
    startLoadingRotator()

    // Abort interno a 28s — un poco antes que el timeout del proxy (30s) para
    // que el catch reciba un AbortError limpio en vez de HTML del gateway.
    const ctrl = new AbortController()
    const abortTimer = window.setTimeout(() => ctrl.abort(), 28_000)

    try {
      const res = await fetch('/api/valuar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        signal: ctrl.signal,
      })
      // Parseo robusto: si el proxy devolvió HTML (504/503), no rompemos con
      // "Unexpected token '<'". Leemos como texto y mostramos mensaje útil.
      const raw = await res.text()
      let data: { error?: string; hint?: string; [k: string]: unknown } = {}
      try {
        data = JSON.parse(raw) as typeof data
      } catch {
        const isTimeout = res.status === 504 || res.status === 503 || res.status === 502
        errorBox.textContent = isTimeout
          ? 'El servidor tardó demasiado. Probá de nuevo en unos segundos.'
          : `Respuesta inesperada del servidor (${res.status}). Probá de nuevo.`
        errorBox.classList.remove('hidden')
        empty.classList.remove('hidden')
        return
      }
      if (!res.ok) {
        let msg = data.error || 'Error desconocido'
        if (data.hint) msg += ` — ${data.hint}`
        errorBox.textContent = msg
        errorBox.classList.remove('hidden')
        empty.classList.remove('hidden')
        return
      }
      const valData = data as unknown as Result
      result.innerHTML = renderResult(valData, payload)
      result.classList.remove('hidden')
      wireResultCTAs(valData, payload)
    } catch (err) {
      const e = err as Error
      const aborted = e.name === 'AbortError'
      errorBox.textContent = aborted
        ? 'La valuación tardó demasiado. Probá de nuevo en unos segundos.'
        : 'No pudimos contactar el servidor: ' + String(e.message)
      errorBox.classList.remove('hidden')
      empty.classList.remove('hidden')
    } finally {
      window.clearTimeout(abortTimer)
      stopLoadingRotator()
      loading.classList.add('hidden')
      setBtnLoading(submitBtn, false)
      submitLabel.textContent = 'Valuar mi propiedad'
    }
  })
</script>
