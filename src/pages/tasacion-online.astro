            </a>

            <button type="button" id="cta-email-toggle"
                    class="block w-full p-4 rounded-2xl border border-border hover:border-accent/40 hover:bg-accent/5 active:scale-[0.99] transition-all group text-left">
              <div class="flex items-center gap-3">
                <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-elevated border border-border flex items-center justify-center text-accent">
