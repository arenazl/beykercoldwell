---
import Layout from '../layouts/Layout.astro'
import Stepper from '../components/Stepper.astro'
import AddressInput from '../components/AddressInput.astro'
import Select from '../components/Select.astro'
import { CONTACT } from '../data/site'

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Tasación inteligente', url: '/tasacion-online' },
]

const types = ['Departamento', 'Casa', 'PH', 'Casa Quinta', 'Lote', 'Local', 'Oficina']
const states: { value: string; label: string }[] = [
  { value: 'a estrenar', label: 'A estrenar' },
  { value: 'excelente', label: 'Excelente' },
  { value: 'bueno', label: 'Bueno' },
  { value: 'regular', label: 'Regular' },
  { value: 'a refaccionar', label: 'A refaccionar' },
]
const featureOptions = [
  'Cochera', 'Pileta', 'Terraza', 'Balcón', 'Patio', 'Parrilla', 'Quincho',
  'Amenities', 'Solarium', 'Vista despejada', 'Luminoso', 'Apto profesional',
  'Apto crédito', 'Seguridad 24h',
]
---

<Layout
  title="Tasación inteligente · Valuación instantánea con Análisis Comparativo"
  description="Valuá tu propiedad: banda de precio, comparables de la zona, factores de ajuste y estrategia comercial en menos de 30 segundos."
  schemaType="Service"
  breadcrumbs={breadcrumbs}
>
  <section class="border-b border-border bg-elevated/30">
    <div class="container-app py-8 lg:py-12">
      <div class="max-w-3xl">
        <div class="section-eyebrow mb-2 flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z" />
          </svg>
          Tasación inteligente
        </div>
        <h1 class="text-2xl md:text-4xl font-bold tracking-tightest leading-[1.05] mb-3">
          Valuá tu propiedad<br />
          <span class="text-accent">en 30 segundos.</span>
        </h1>
        <p class="text-sm md:text-base text-muted leading-relaxed">
          Análisis Comparativo de Mercado: banda de precio, comparables de la zona, factores
          que suman y restan, y estrategia comercial recomendada. Es una valuación orientativa —
          la final requiere visita presencial.
        </p>
      </div>
    </div>
  </section>

  <section class="container-app py-8">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">
      <form id="val-form" class="lg:col-span-5 flex flex-col scroll-mt-32" data-wa-phone={CONTACT.phone_e164}>
        <!-- Wizard header con progreso — sin recuadro, full width -->
        <header class="mb-4 flex-shrink-0">
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-accent text-bg text-[11px] font-bold" id="wiz-step-num">1</span>
              <span class="text-[11px] uppercase tracking-wider text-muted font-semibold">de 7</span>
            </div>
            <button type="button" id="wiz-skip" class="hidden text-[11px] font-semibold text-muted hover:text-accent transition-colors">
              Saltar paso →
            </button>
          </div>
          <h2 id="wiz-step-title" class="text-lg sm:text-xl font-bold leading-tight mb-3">¿Qué propiedad querés valuar?</h2>
          <div class="h-0.5 rounded-full bg-border/60 overflow-hidden">
            <div id="wiz-progress" class="h-full bg-gradient-to-r from-gold via-accent to-accent transition-all duration-500 ease-out" style="width: 14.3%"></div>
          </div>
        </header>

        <div id="wiz-body" class="flex-1 min-h-0">
          <!-- Step 1: Tipo + Estado -->
          <div data-wiz-step="1" data-wiz-title="¿Qué propiedad querés valuar?" class="wiz-step grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Tipo</label>
              <Select id="f-type" options={types} selected={types[0]} required triggerClass="px-3 py-2.5 text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Estado</label>
              <Select id="f-state" options={states} selected={states[0].value} required triggerClass="px-3 py-2.5 text-sm" />
            </div>
          </div>

          <!-- Step 2: Ubicación — un solo campo con autocomplete verificado contra OSM/Nominatim -->
          <div data-wiz-step="2" data-wiz-title="¿Dónde está?" data-wiz-verified-required="true" class="wiz-step hidden">
            <AddressInput required />
          </div>

          <!-- Step 3: Detalles del lugar (opcional) -->
          <div data-wiz-step="3" data-wiz-title="Detalles del lugar (opcional)" data-wiz-skippable="true" class="wiz-step hidden">
            <div class="grid grid-cols-3 gap-3">
              <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold uppercase tracking-wider text-muted">Piso</label>
                <input id="f-floor" type="text" placeholder="5"
                       class="px-3 py-2.5 rounded-xl bg-bg border border-border text-text focus:outline-none focus:border-accent" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold uppercase tracking-wider text-muted">Depto</label>
                <input id="f-unit" type="text" placeholder="A"
                       class="px-3 py-2.5 rounded-xl bg-bg border border-border text-text focus:outline-none focus:border-accent" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold uppercase tracking-wider text-muted">Orientación</label>
                <Select
                  id="f-orientation"
                  placeholder="—"
                  triggerClass="px-3 py-2.5 text-sm"
                  options={[
                    { value: '', label: '—' },
                    { value: 'Norte', label: 'Norte' },
                    { value: 'Sur', label: 'Sur' },
                    { value: 'Este', label: 'Este' },
                    { value: 'Oeste', label: 'Oeste' },
                    { value: 'Frente', label: 'Frente' },
                    { value: 'Contrafrente', label: 'Contrafrente' },
                    { value: 'Lateral', label: 'Lateral' },
                  ]}
                />
              </div>
            </div>
            <p class="text-xs text-muted mt-3">Si no aplica (casa, lote, etc.) podés saltar este paso.</p>
          </div>

          <!-- Step 4: Tamaño -->
          <div data-wiz-step="4" data-wiz-title="¿Qué tan grande es?" data-wiz-required="f-surface-total" class="wiz-step hidden grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Sup. total (m²)</label>
              <input id="f-surface-total" type="number" min="1" required class="px-3 py-2.5 rounded-xl bg-bg border border-border text-text focus:outline-none focus:border-accent" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Sup. cubierta (m²)</label>
              <input id="f-surface-covered" type="number" min="1" class="px-3 py-2.5 rounded-xl bg-bg border border-border text-text focus:outline-none focus:border-accent" />
            </div>
          </div>

          <!-- Step 5: Ambientes -->
          <div data-wiz-step="5" data-wiz-title="¿Cuántos ambientes?" class="wiz-step hidden grid grid-cols-3 gap-3">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Ambientes</label>
              <Stepper id="f-rooms" min={1} max={20} placeholder="3" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Dorm.</label>
              <Stepper id="f-bedrooms" min={0} max={15} placeholder="2" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Baños</label>
              <Stepper id="f-bathrooms" min={0} max={10} placeholder="1" />
            </div>
          </div>

          <!-- Step 6: Antigüedad + Expensas -->
          <div data-wiz-step="6" data-wiz-title="Antigüedad y expensas" data-wiz-skippable="true" class="wiz-step hidden grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Antigüedad (años)</label>
              <Stepper id="f-age" min={0} max={150} placeholder="0 = a estrenar" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Expensas (ARS)</label>
              <input id="f-expenses" type="text" inputmode="numeric" autocomplete="off" data-money-mask placeholder="80.000" class="px-3 py-2.5 rounded-xl bg-bg border border-border text-text focus:outline-none focus:border-accent" />
            </div>
          </div>

          <!-- Step 7: Características + Notas + Generar -->
          <div data-wiz-step="7" data-wiz-title="Detalles finales" class="wiz-step hidden space-y-4">
            <div class="flex flex-col gap-2">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Características (opcional)</label>
              <div class="flex flex-wrap gap-2">
                {featureOptions.map((f) => (
                  <label class="cursor-pointer">
                    <input type="checkbox" name="feature" value={f} class="peer sr-only" />
                    <span class="inline-block px-3 py-1.5 text-xs rounded-full border border-border text-muted bg-bg transition-all hover:border-accent/40 peer-checked:bg-accent peer-checked:text-white peer-checked:border-accent">
                      {f}
                    </span>
                  </label>
                ))}
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold uppercase tracking-wider text-muted">Notas (opcional)</label>
              <textarea id="f-notes" rows="2" placeholder="Detalles relevantes: orientación, vista, planta, etc."
                        class="px-3 py-2.5 rounded-xl bg-bg border border-border text-text focus:outline-none focus:border-accent resize-none"></textarea>
            </div>
            <p class="text-xs text-muted leading-relaxed">
              Valuación orientativa. Para una tasación profesional con visita presencial,
              <a href="/tasaciones" class="text-accent hover:underline">solicitala acá</a>.
            </p>
          </div>
        </div>

        <div id="wiz-validation" class="hidden mt-2 p-2 rounded-lg bg-amber-500/10 border border-amber-500/30 text-amber-600 text-xs"></div>

        <!-- Wizard footer / nav -->
        <footer class="mt-4 flex-shrink-0 flex items-center justify-between gap-2">
          <button type="button" id="wiz-prev" class="btn-secondary disabled:opacity-30 disabled:pointer-events-none">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            Atrás
          </button>
          <button type="button" id="wiz-next" class="btn-primary">
            Siguiente
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
          <button type="submit" id="val-submit" class="btn-primary hidden">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z" />
            </svg>
            <span id="val-submit-label">Valuar mi propiedad</span>
          </button>
        </footer>
      </form>

      <div class="lg:col-span-7 min-w-0">
        <div id="val-empty" class="bg-elevated/40 border border-dashed border-border rounded-2xl p-10 text-center">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-accent/10 text-accent flex items-center justify-center mb-4">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 3v18h18M7 12l4-4 4 4 6-6" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Esperando los datos</h3>
          <p class="text-muted text-sm leading-relaxed max-w-md mx-auto">
            Completá el formulario de la izquierda y vas a recibir la valuación con banda de precio,
            comparables, factores de ajuste y estrategia comercial.
          </p>
        </div>

        <div id="val-loading" class="hidden bg-elevated border border-border rounded-2xl p-10 text-center">
          <div class="w-12 h-12 mx-auto rounded-full border-2 border-accent/20 border-t-accent animate-spin mb-4"></div>
          <h3 id="val-loading-title" class="text-lg font-bold mb-1 transition-opacity duration-300">Analizando el mercado…</h3>
          <p id="val-loading-sub" class="text-muted text-sm transition-opacity duration-300">Cruzando datos comparables y factores de la zona.</p>
        </div>

        <div id="val-error" class="hidden p-5 rounded-2xl bg-red-500/10 border border-red-500/30 text-red-600 text-sm"></div>

        <div id="val-result" class="hidden space-y-5"></div>
      </div>
    </div>
  </section>

  <section class="section bg-elevated/40 border-y border-border">
    <div class="container-app">
      <div class="max-w-3xl mx-auto text-center">
        <div class="section-eyebrow mb-3">Próximo paso</div>
        <h2 class="section-title mb-4">¿Querés una tasación profesional con visita?</h2>
        <p class="text-muted mb-6 leading-relaxed">
          La valuación inteligente te da una banda orientativa. La tasación profesional ajusta esa banda con visita presencial,
          inspección detallada y estrategia comercial diseñada para tu propiedad.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/tasaciones" class="btn-primary">Solicitar tasación profesional</a>
          <a href={CONTACT.whatsapp_link} target="_blank" rel="noopener" class="btn-secondary">Hablar por WhatsApp</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Wizard compacto — bajamos ~30% el tamaño visual respecto al default
     de la app, manteniendo el aspecto pero ahorrando vertical. */
  #val-form select,
  #val-form input[type="text"],
  #val-form input[type="number"],
  #val-form textarea {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    font-size: 0.875rem;
  }
  #val-form label {
    font-size: 0.65rem;
  }
  #val-form .stepper-input {
    padding-top: 0.4rem;
    padding-bottom: 0.4rem;
    font-size: 0.95rem;
  }
  #val-form .stepper-btn {
    width: 2rem;
  }
  #val-form .wiz-step {
    gap: 0.5rem;
  }
  #val-form .wiz-step.space-y-4 > * + * {
    margin-top: 0.5rem;
  }
  #val-form .btn-primary,
  #val-form .btn-secondary {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    padding-left: 1.1rem;
    padding-right: 1.1rem;
    font-size: 0.875rem;
  }

  /* Entrada del bloque de resultado */
  .val-result-anim {
    animation: val-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes val-enter {
    from { opacity: 0; transform: translateY(16px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  /* Pop del check verde */
  .val-check-pop {
    animation: val-pop 0.5s cubic-bezier(0.22, 1.5, 0.36, 1) 0.2s both;
  }
  @keyframes val-pop {
    from { opacity: 0; transform: scale(0); }
    to { opacity: 1; transform: scale(1); }
  }

  .wiz-step {
    animation: wiz-enter 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .wiz-step.wiz-back {
    animation: wiz-enter-back 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes wiz-enter {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes wiz-enter-back {
    from { opacity: 0; transform: translateX(-20px); }
    to { opacity: 1; transform: translateX(0); }
  }
  .wiz-shake {
    animation: wiz-shake 0.4s ease-in-out;
  }
  @keyframes wiz-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }
</style>

<script>
  import { initMoneyMasks, unmaskMoney } from '../lib/money-mask'
  import { setBtnLoading } from '../lib/btn-loading'
  import { initSteppers } from '../lib/stepper'

  initMoneyMasks()
  initSteppers()

  // ====================================================================
  // Wizard: navegación paso a paso
  // ====================================================================
  ;(() => {
    const formEl = document.getElementById('val-form') as HTMLFormElement
    const steps = Array.from(document.querySelectorAll<HTMLElement>('[data-wiz-step]'))
    if (!steps.length) return
    const total = steps.length
    const stepNum = document.getElementById('wiz-step-num') as HTMLSpanElement
    const stepTitle = document.getElementById('wiz-step-title') as HTMLHeadingElement
    const progress = document.getElementById('wiz-progress') as HTMLDivElement
    const prevBtn = document.getElementById('wiz-prev') as HTMLButtonElement
    const nextBtn = document.getElementById('wiz-next') as HTMLButtonElement
    const skipBtn = document.getElementById('wiz-skip') as HTMLButtonElement
    const submitBtn = document.getElementById('val-submit') as HTMLButtonElement
    const validation = document.getElementById('wiz-validation') as HTMLDivElement
    let current = 1

    function showStep(n: number, direction: 'forward' | 'back') {
      validation.classList.add('hidden')
      steps.forEach((el) => {
        const idx = Number(el.dataset.wizStep)
        el.classList.remove('wiz-step', 'wiz-back')
        if (idx === n) {
          el.classList.remove('hidden')
          // Force reflow para que la animación se reinicie cada vez.
          void el.offsetWidth
          el.classList.add('wiz-step')
          if (direction === 'back') el.classList.add('wiz-back')
          stepTitle.textContent = el.dataset.wizTitle || ''
          const skippable = el.dataset.wizSkippable === 'true'
          skipBtn.classList.toggle('hidden', !skippable)
          // Foco al primer input del paso
          const firstInput = el.querySelector<HTMLElement>('input, select, textarea')
          if (firstInput) setTimeout(() => firstInput.focus({ preventScroll: true }), 50)
        } else {
          el.classList.add('hidden')
        }
      })
      stepNum.textContent = String(n)
      progress.style.width = `${(n / total) * 100}%`
      prevBtn.disabled = n === 1
      const isLast = n === total
      nextBtn.classList.toggle('hidden', isLast)
      submitBtn.classList.toggle('hidden', !isLast)
      current = n

      // Asegurar que el header del paso quede visible por encima de los
      // sticky bars (TopBanner + nav). Solo si no es el primer paso o si el
      // form se salió del viewport — evita scroll innecesario.
      if (n > 1) {
        requestAnimationFrame(() => {
          formEl.scrollIntoView({ behavior: 'smooth', block: 'start' })
        })
      }
    }

    function validateStep(n: number): boolean {
      const el = steps.find((s) => Number(s.dataset.wizStep) === n)
      if (!el) return true

      // Requerimientos por id (campo común).
      const requiredIds = (el.dataset.wizRequired || '').split(',').filter(Boolean)
      for (const id of requiredIds) {
        const input = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null
        if (!input) continue
        if (!input.value.trim()) {
          validation.textContent = `Completá "${input.previousElementSibling?.textContent?.trim() || 'este campo'}" para continuar.`
          validation.classList.remove('hidden')
          input.focus()
          input.classList.add('wiz-shake')
          setTimeout(() => input.classList.remove('wiz-shake'), 500)
          return false
        }
      }

      // Requerimiento especial: dirección verificada contra Nominatim.
      // El step lo declara con `data-wiz-verified-required="true"` y el
      // componente AddressInput setea data-verified en su root.
      if (el.dataset.wizVerifiedRequired === 'true') {
        const addr = document.getElementById('address-input') as HTMLDivElement | null
        if (!addr || addr.dataset.verified !== 'true') {
          validation.textContent = 'Elegí una dirección de la lista para verificarla.'
          validation.classList.remove('hidden')
          const search = document.getElementById('f-address-search') as HTMLInputElement | null
          if (search) {
            search.focus()
            search.classList.add('wiz-shake')
            setTimeout(() => search.classList.remove('wiz-shake'), 500)
          }
          return false
        }
      }

      return true
    }

    nextBtn.addEventListener('click', () => {
      if (!validateStep(current)) return
      if (current < total) showStep(current + 1, 'forward')
    })
    prevBtn.addEventListener('click', () => {
      if (current > 1) showStep(current - 1, 'back')
    })
    skipBtn.addEventListener('click', () => {
      if (current < total) showStep(current + 1, 'forward')
    })

    // Enter en cualquier input avanza al siguiente paso (excepto en textarea / último paso).
    formEl.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter') return
      const target = e.target as HTMLElement
      if (target.tagName === 'TEXTAREA') return
      if (current < total) {
        e.preventDefault()
        nextBtn.click()
      }
    })

    showStep(1, 'forward')
  })()

  type Band = { low: number; typical: number; high: number }
  type Comparable = {
    description: string
    surfaceM2: number
    pricePerM2USD: number
    totalPriceUSD: number
    reason: string
  }
  type AnchorComparable = {
    title: string
    location: string
    surfaceM2: number
    totalPriceUSD: number
    pricePerM2USD: number
  }
  type Anchor = {
    scope: 'zona' | 'provincia' | 'nacional'
    type: string
    location: string
    count: number
    pricePerM2USD: { min: number; p25: number; median: number; p75: number; max: number }
    comparables: AnchorComparable[]
  }
  type Result = {
    pricePerM2USD: Band
    totalPriceUSD: Band
    confidence: 'alta' | 'media' | 'baja'
    marketSummary: string
    comparables: Comparable[]
    factorsUp: string[]
    factorsDown: string[]
    commercialStrategy: string
    recommendations: string[]
    caveats: string
    anchor: Anchor | null
  }

  const form = document.getElementById('val-form') as HTMLFormElement
  const submitBtn = document.getElementById('val-submit') as HTMLButtonElement
  const submitLabel = document.getElementById('val-submit-label') as HTMLSpanElement
  const empty = document.getElementById('val-empty') as HTMLDivElement
  const loading = document.getElementById('val-loading') as HTMLDivElement
  const loadingTitle = document.getElementById('val-loading-title') as HTMLHeadingElement
  const loadingSub = document.getElementById('val-loading-sub') as HTMLParagraphElement
  const errorBox = document.getElementById('val-error') as HTMLDivElement
  const result = document.getElementById('val-result') as HTMLDivElement

  // Mensajes rotativos del loader. Son dummy (no representan trabajo real),
  // pero dan sensación de progreso para que no parezca colgado durante los
  // ~10-25s que tarda Gemini.
  const LOADING_STEPS: Array<{ title: string; sub: string }> = [
    { title: 'Analizando el mercado…', sub: 'Cruzando datos comparables y factores de la zona.' },
    { title: 'Buscando comparables…', sub: 'Filtrando propiedades reales del catálogo en tu zona.' },
    { title: 'Calibrando precios…', sub: 'Ajustando bandas según tu superficie y estado.' },
    { title: 'Evaluando factores…', sub: 'Antigüedad, orientación, amenities y posición.' },
    { title: 'Estimando cierre…', sub: 'Aplicando descuento típico de negociación argentino.' },
    { title: 'Armando estrategia…', sub: 'Calculando margen y tiempo esperado en mercado.' },
    { title: 'Casi listo…', sub: 'Redondeando bandas y comparables finales.' },
  ]
  let loadingTimer: number | null = null
  function startLoadingRotator() {
    let i = 0
    loadingTitle.textContent = LOADING_STEPS[0].title
    loadingSub.textContent = LOADING_STEPS[0].sub
    loadingTimer = window.setInterval(() => {
      i = (i + 1) % LOADING_STEPS.length
      loadingTitle.style.opacity = '0'
      loadingSub.style.opacity = '0'
      window.setTimeout(() => {
        loadingTitle.textContent = LOADING_STEPS[i].title
        loadingSub.textContent = LOADING_STEPS[i].sub
        loadingTitle.style.opacity = '1'
        loadingSub.style.opacity = '1'
      }, 250)
    }, 2800)
  }
  function stopLoadingRotator() {
    if (loadingTimer !== null) {
      window.clearInterval(loadingTimer)
      loadingTimer = null
    }
    loadingTitle.style.opacity = '1'
    loadingSub.style.opacity = '1'
  }

  function num(id: string): number | undefined {
    const el = document.getElementById(id) as HTMLInputElement | null
    if (!el || !el.value) return undefined
    const n = Number(el.value)
    return Number.isFinite(n) ? n : undefined
  }
  function str(id: string): string | undefined {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null
    if (!el) return undefined
    const v = el.value.trim()
    return v || undefined
  }
  function fmtUSD(v: number) {
    return 'USD ' + Math.round(v).toLocaleString('es-AR')
  }
  function fmtUSDperM2(v: number) {
    return 'USD ' + Math.round(v).toLocaleString('es-AR') + '/m²'
  }
  function escape(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!))
  }
  function confidenceBadge(c: 'alta' | 'media' | 'baja') {
    const cls = c === 'alta'
      ? 'bg-green-500/10 text-green-600 border-green-500/30'
      : c === 'media'
        ? 'bg-amber-500/10 text-amber-600 border-amber-500/30'
        : 'bg-red-500/10 text-red-600 border-red-500/30'
    return `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border ${cls}">
      <span class="w-1.5 h-1.5 rounded-full bg-current"></span>Confianza ${c}
    </span>`
  }

  function renderAnchorStrip(anchor: Anchor | null): string {
    // Sin ancla del catálogo propio → caemos al texto genérico anterior.
    if (!anchor) {
      return `
        <div class="flex items-center justify-center gap-2 mb-5 text-[11px] text-muted">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M9 12l2 2 4-4M21 12c0 5-4 9-9 9s-9-4-9-9 4-9 9-9 9 4 9 9z" />
          </svg>
          <span>Análisis Comparativo de Mercado · valuación basada en datos generales del mercado argentino</span>
        </div>
      `
    }
    const scopeLabel = anchor.scope === 'zona'
      ? `en ${escape(anchor.location)}`
      : anchor.scope === 'provincia'
        ? `en ${escape(anchor.location)} (sin match exacto en barrio)`
        : `de tipo ${escape(anchor.type)} (sin match en zona)`
    const median = Math.round(anchor.pricePerM2USD.median).toLocaleString('es-AR')
    const min = Math.round(anchor.pricePerM2USD.min).toLocaleString('es-AR')
    const max = Math.round(anchor.pricePerM2USD.max).toLocaleString('es-AR')
    return `
      <div class="mb-5 p-4 rounded-xl border border-accent/20 bg-accent/5">
        <div class="flex items-center gap-2 mb-2 text-[11px] font-semibold uppercase tracking-wider text-accent">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M9 12l2 2 4-4M21 12c0 5-4 9-9 9s-9-4-9-9 4-9 9-9 9 4 9 9z" />
          </svg>
          <span>Anclado al catálogo Coldwell Banker Argentina</span>
        </div>
        <p class="text-[12px] text-muted leading-relaxed mb-2">
          Esta valuación se basó en <span class="text-text font-bold">${anchor.count} propiedades reales</span>
          ${scopeLabel} de nuestro catálogo, con USD/m² entre
          <span class="text-text font-semibold">${min}</span> y
          <span class="text-text font-semibold">${max}</span>
          (mediana: <span class="text-accent font-bold">USD ${median}/m²</span>).
        </p>
        <details class="group">
          <summary class="cursor-pointer text-[11px] text-accent font-semibold inline-flex items-center gap-1 hover:underline list-none">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                 class="transition-transform group-open:rotate-90">
              <polyline points="9 18 15 12 9 6" />
            </svg>
            Ver propiedades comparables del catálogo
          </summary>
          <ul class="mt-3 space-y-2 text-[11px]">
            ${anchor.comparables.map((c) => `
              <li class="flex items-start gap-2 p-2 rounded-lg bg-bg/60 border border-border/50">
                <div class="flex-1 min-w-0">
                  <div class="text-text font-semibold truncate">${escape(c.title)}</div>
                  <div class="text-muted text-[10px]">${escape(c.location)} · ${c.surfaceM2} m²</div>
                </div>
                <div class="flex-shrink-0 text-right">
                  <div class="text-text font-bold">USD ${c.totalPriceUSD.toLocaleString('es-AR')}</div>
                  <div class="text-muted text-[10px]">${c.pricePerM2USD.toLocaleString('es-AR')} USD/m²</div>
                </div>
              </li>
            `).join('')}
          </ul>
        </details>
      </div>
    `
  }

  function renderBandBar(band: Band) {
    const range = band.high - band.low || 1
    const typicalPct = ((band.typical - band.low) / range) * 100
    return `
      <div class="space-y-2">
        <div class="relative h-2 rounded-full bg-border overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-r from-accent/30 via-gold to-accent/30"></div>
          <div class="absolute top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-accent border-2 border-bg shadow-md"
               style="left: calc(${typicalPct.toFixed(1)}% - 6px)"></div>
        </div>
        <div class="flex items-center justify-between text-xs text-muted">
          <span>${fmtUSD(band.low)}</span>
          <span class="font-semibold text-accent">${fmtUSD(band.typical)}</span>
          <span>${fmtUSD(band.high)}</span>
        </div>
      </div>
    `
  }

  /** Forma del payload que se envía a /api/valuar y se reusa para los CTAs. */
  type ValuationPayload = {
    type: string
    state: string
    location?: string
    street?: string
    streetNumber?: string
    address?: string
    lat?: number
    lng?: number
    floor?: string
    unit?: string
    orientation?: string
    surfaceTotalM2?: number
    surfaceCoveredM2?: number
    rooms?: number
    bedrooms?: number
    bathrooms?: number
    ageYears?: number
    expensesArs?: number
    features: string[]
    notes?: string
  }

  /**
   * Genera un código corto de tracking para que el asesor identifique este
   * caso al recibir el mensaje. No es seguridad, es solo correlación humana.
   */
  function makeTrackingCode(): string {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'
    let out = 'BEY-'
    for (let i = 0; i < 4; i++) out += chars[Math.floor(Math.random() * chars.length)]
    return out
  }

