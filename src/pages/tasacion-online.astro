              <div class="flex gap-2">
                <input id="cta-email-input" type="email" required placeholder="vos@mail.com"
                       class="flex-1 px-3 py-2.5 rounded-xl bg-bg border border-border text-text focus:outline-none focus:border-accent" />
                <button type="submit" id="cta-email-submit" class="btn-primary justify-center whitespace-nowrap">
                  Enviar
                </button>
              </div>
              <p id="cta-email-feedback" class="hidden text-xs mt-2"></p>
            </form>
