                <span>Máximo</span>
              </div>
              <div class="flex items-center justify-between text-sm font-bold mt-1">
                <span data-locked-value class="inline-block" style="filter: blur(7px);">${fmtUSD(r.totalPriceUSD.low)}</span>
                <span data-locked-value class="inline-block text-gold" style="filter: blur(7px);">${fmtUSD(r.totalPriceUSD.typical)}</span>
                <span data-locked-value class="inline-block" style="filter: blur(7px);">${fmtUSD(r.totalPriceUSD.high)}</span>
              </div>
            </div>
