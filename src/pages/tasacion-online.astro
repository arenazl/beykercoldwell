          <!-- Tira de "valuación profesional" — si hay ancla del catálogo,
               mostramos los datos reales que la sustentan (transparencia para
               asesores y credibilidad para el visitante). -->
          ${renderAnchorStrip(r.anchor)}

          <!-- 2 vías de desbloqueo -->
          <div class="space-y-3" id="unlock-ctas">
