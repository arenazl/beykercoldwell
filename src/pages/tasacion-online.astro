          <div class="bg-accent text-bg rounded-2xl p-5 mb-3 relative overflow-hidden">
            <span aria-hidden="true" class="absolute -top-1/2 right-0 w-64 aspect-square bg-gold/20 rounded-full blur-3xl"></span>
            <div class="relative">
              <div class="text-xs uppercase tracking-wider text-gold mb-1 font-semibold">Precio típico de mercado</div>
              <div class="text-4xl md:text-5xl font-bold tracking-tightest mb-4">
                <span data-locked-value class="inline-block" style="filter: blur(12px);">${fmtUSD(r.totalPriceUSD.typical)}</span>
