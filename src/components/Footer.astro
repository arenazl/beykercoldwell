---
import { SITE, CONTACT, SOCIAL, NAV, NAV_TOOLS_IA, LOGOS } from '../data/site'
const year = new Date().getFullYear()

// Build info — se evalúa al hacer build. Tanto el ISO como el commit short
// quedan congelados en el HTML generado. Sirve para confirmar a simple
// vista qué versión está sirviendo Netlify (ver footer + console).
const BUILD_TIME = new Date().toISOString()
const BUILD_COMMIT = (process.env.COMMIT_REF ?? process.env.GITHUB_SHA ?? 'dev').slice(0, 7)
const BUILD_LABEL = `v${BUILD_TIME.slice(0, 16).replace('T', ' ')} · ${BUILD_COMMIT}`
---

<footer class="border-t border-border bg-bg mt-12">
  <div class="container-app py-16 grid grid-cols-1 md:grid-cols-12 gap-10">
    <div class="md:col-span-3">
      <a href="/" class="inline-block mb-4" aria-label="Coldwell Banker Beyker — Inicio">
        <img
          src={LOGOS.primary}
          alt="Coldwell Banker Beyker"
          class="h-10 w-auto"
          width="180"
          height="40"
        />
      </a>
      <p class="text-sm text-muted leading-relaxed max-w-xs">
        {SITE.description}
      </p>
      <div class="flex items-center gap-3 mt-5">
        <a href={SOCIAL.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="w-9 h-9 rounded-full border border-border flex items-center justify-center text-muted hover:text-accent hover:border-accent transition-all">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
        </a>
        <a href={SOCIAL.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="w-9 h-9 rounded-full border border-border flex items-center justify-center text-muted hover:text-accent hover:border-accent transition-all">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href={SOCIAL.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class="w-9 h-9 rounded-full border border-border flex items-center justify-center text-muted hover:text-accent hover:border-accent transition-all">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>

    <div class="md:col-span-2">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-muted mb-4">Navegación</h3>
      <ul class="space-y-2">
        {NAV.map((item) => (
          <li>
            <a href={item.href} class="text-sm text-text/80 hover:text-accent transition-colors">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-2">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-muted mb-4">Herramientas inteligentes</h3>
      <ul class="space-y-2">
        {NAV_TOOLS_IA.map((t) => (
          <li><a href={t.href} class="text-sm text-text/80 hover:text-accent transition-colors">{t.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-2">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-muted mb-4">Accesos</h3>
      <ul class="space-y-2">
        <li><a href="/unite" class="text-sm text-text/80 hover:text-accent transition-colors">Unite al equipo</a></li>
        <li><a href="/franquicias" class="text-sm text-text/80 hover:text-accent transition-colors">Franquicias</a></li>
        <li><a href="/tecnologia" class="text-sm text-text/80 hover:text-accent transition-colors">Tecnología</a></li>
        <li><a href="/inversores" class="text-sm text-text/80 hover:text-accent transition-colors">Inversores</a></li>
        <li><a href="/tasaciones" class="text-sm text-text/80 hover:text-accent transition-colors">Tasación profesional</a></li>
        <li><a href="/emprendimientos" class="text-sm text-text/80 hover:text-accent transition-colors">Emprendimientos</a></li>
      </ul>
    </div>

    <div class="md:col-span-3">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-muted mb-4">Contacto</h3>
      <ul class="space-y-2 text-sm">
        <li class="text-text/80">
          {CONTACT.address.line1}<br />
          {CONTACT.address.line2}
        </li>
        <li>
          <a href={`mailto:${CONTACT.email}`} class="text-text/80 hover:text-accent transition-colors break-all">
            {CONTACT.email}
          </a>
        </li>
        <li>
          <a href={CONTACT.whatsapp_link} target="_blank" rel="noopener" class="text-text/80 hover:text-accent transition-colors">
            WhatsApp · {CONTACT.phone_display}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-border">
    <div class="container-app py-6 flex flex-col gap-2 text-xs text-muted">
      <p class="leading-relaxed">
        © {year} {SITE.legal}. Todos los derechos reservados. Coldwell Banker® y los logotipos de Coldwell Banker son
        marcas de servicio de propiedad de Coldwell Banker Real Estate LLC. El sistema Coldwell Banker® está compuesto por
        oficinas propias y oficinas adheridas al Sistema Coldwell Banker que son de propiedad y operación independiente.
      </p>
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <span>Buenos Aires, Argentina</span>
        <span class="text-[10px] text-muted/60 font-mono tracking-tight" title="Build identifier">
          {BUILD_LABEL}
        </span>
      </div>
    </div>
  </div>
</footer>

<script is:inline define:vars={{ label: BUILD_LABEL, ts: BUILD_TIME, commit: BUILD_COMMIT }}>
  // Imprime una sola línea por carga así podés confirmar en consola
  // (incluso desde mobile via Safari/Chrome DevTools remoto) que estás
  // viendo el último build deployado.
  // eslint-disable-next-line no-console
  console.log(
    '%c[Beyker]%c build ' + label,
    'background:#C9A45A;color:#0b1120;padding:2px 6px;border-radius:3px;font-weight:bold',
    'color:#94a3b8',
  )
</script>
