---
import { FILTERS } from '../data/properties'
import Select from './Select.astro'
---

<form
  action="/propiedades"
  method="get"
  class="bg-elevated border border-border rounded-2xl shadow-xl p-4 lg:p-6"
>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
    <div class="flex flex-col gap-1.5 lg:col-span-2">
      <label for="q" class="text-xs font-semibold uppercase tracking-wider text-muted">
        Palabras clave
      </label>
      <input
        type="text"
        id="q"
        name="q"
        placeholder="Barrio, calle, características…"
        class="w-full px-4 py-3 rounded-xl bg-bg border border-border text-text placeholder:text-muted/70
               focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all"
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label for="operacion" class="text-xs font-semibold uppercase tracking-wider text-muted">
        Operación
      </label>
      <Select
        id="operacion"
        name="operacion"
        placeholder="Todas"
        options={[
          { value: '', label: 'Todas' },
          ...FILTERS.operaciones.map((op) => ({
            value: op,
            label: op === 'venta' ? 'Venta' : 'Alquiler',
          })),
        ]}
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label for="tipo" class="text-xs font-semibold uppercase tracking-wider text-muted">
        Tipo
      </label>
      <Select
        id="tipo"
        name="tipo"
        placeholder="Todos"
        options={[
          { value: '', label: 'Todos' },
          ...FILTERS.tipos.map((t) => ({ value: t, label: t })),
        ]}
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label for="ubicacion" class="text-xs font-semibold uppercase tracking-wider text-muted">
        Ubicación
      </label>
      <Select
        id="ubicacion"
        name="ubicacion"
        placeholder="Todas"
        searchable
        options={[
          { value: '', label: 'Todas' },
          ...FILTERS.ubicaciones.map((u) => ({ value: u, label: u })),
        ]}
      />
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 mt-4">
    <a href="/propiedades" class="text-sm text-muted hover:text-text transition-colors">
      Búsqueda avanzada →
    </a>
    <button type="submit" class="btn-primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      Buscar
    </button>
  </div>
</form>
