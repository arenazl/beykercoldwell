---
interface Props {
  /** CSS selector del contenedor cuyas children-cards se ordenan. */
  target: string
  className?: string
}
const { target, className = '' } = Astro.props

const SORTS = [
  { key: 'destacados', label: 'Destacados' },
  { key: 'price-asc', label: 'Menor precio' },
  { key: 'price-desc', label: 'Mayor precio' },
  { key: 'm2-desc', label: 'Más superficie' },
  { key: 'bedrooms-desc', label: 'Más ambientes' },
]
---

<div data-sortbar={target} class:list={['flex flex-wrap items-center gap-2', className]}>
  <span class="text-xs uppercase tracking-wider text-muted font-semibold mr-1">Ordenar:</span>
  {SORTS.map((s, i) => (
    <button
      type="button"
      data-sort={s.key}
      class:list={[
        'px-3 py-1.5 rounded-full text-xs font-semibold transition-all duration-200 active:scale-95',
        i === 0
          ? 'bg-accent text-bg shadow-sm shadow-accent/30'
          : 'bg-elevated border border-border text-muted hover:text-text hover:border-accent/40',
      ]}
    >{s.label}</button>
  ))}
</div>

<script>
  type SortKey = 'destacados' | 'price-asc' | 'price-desc' | 'm2-desc' | 'bedrooms-desc'

  const ACTIVE_ON = ['bg-accent', 'text-bg', 'shadow-sm', 'shadow-accent/30']
  const ACTIVE_OFF = ['bg-elevated', 'border', 'border-border', 'text-muted', 'hover:text-text', 'hover:border-accent/40']

  function attrFor(field: 'price' | 'm2' | 'bedrooms') {
    return field === 'price' ? 'sortPrice' : field === 'm2' ? 'sortM2' : 'sortBedrooms'
  }

  function applySort(grid: HTMLElement, key: SortKey) {
    const cards = Array.from(grid.children) as HTMLElement[]
    if (key === 'destacados') {
      cards.sort((a, b) => Number(a.dataset.sortIndex || 0) - Number(b.dataset.sortIndex || 0))
    } else {
      const [field, dir] = key.split('-') as ['price' | 'm2' | 'bedrooms', 'asc' | 'desc']
      const attr = attrFor(field)
      const sign = dir === 'asc' ? 1 : -1
      cards.sort((a, b) => {
        const av = Number((a.dataset as Record<string, string>)[attr])
        const bv = Number((b.dataset as Record<string, string>)[attr])
        const aMissing = !Number.isFinite(av) || av === 0
        const bMissing = !Number.isFinite(bv) || bv === 0
        if (aMissing && bMissing) return 0
        if (aMissing) return 1
        if (bMissing) return -1
        return sign * (av - bv)
      })
    }
    cards.forEach((c) => grid.appendChild(c))
  }

  function snapshotIndices(grid: HTMLElement) {
    Array.from(grid.children).forEach((c, i) => {
      ;(c as HTMLElement).dataset.sortIndex = String(i)
    })
  }

  function setActive(buttons: HTMLButtonElement[], target: HTMLButtonElement) {
    buttons.forEach((b) => {
      b.classList.remove(...ACTIVE_ON)
      b.classList.add(...ACTIVE_OFF)
    })
    target.classList.add(...ACTIVE_ON)
    target.classList.remove(...ACTIVE_OFF)
  }

  function setupBar(bar: HTMLElement) {
    const targetSel = bar.dataset.sortbar
    if (!targetSel) return
    const grid = document.querySelector(targetSel) as HTMLElement | null
    if (!grid) return
    snapshotIndices(grid)
    const buttons = Array.from(bar.querySelectorAll<HTMLButtonElement>('[data-sort]'))
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        setActive(buttons, btn)
        applySort(grid, btn.dataset.sort as SortKey)
      })
    })
    // Permite que páginas con render dinámico reseteen el orden tras cargar
    // nuevos resultados: dispatch `new CustomEvent('sortbar:reinit')` en el grid.
    grid.addEventListener('sortbar:reinit', () => {
      snapshotIndices(grid)
      setActive(buttons, buttons[0])
    })
  }

  document.querySelectorAll<HTMLElement>('[data-sortbar]').forEach(setupBar)
</script>
