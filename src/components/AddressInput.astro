---
/**
 * Input de dirección con autocomplete contra Nominatim (OSM). Sólo deja
 * "verificada" una dirección cuando el usuario eligió una sugerencia de
 * la lista — si tipea libre no avanza.
 *
 * Flujo:
 *  1. El usuario elige una provincia del combobox (con type-to-filter
 *     sobre la lista hardcodeada de las 24 jurisdicciones).
 *  2. Recién ahí se habilita el input de dirección.
 *  3. El autocomplete de Nominatim queda sesgado a esa provincia y
 *     filtramos los resultados para que sólo aparezcan los que matcheen.
 *
 * Mantiene los IDs `f-location`, `f-street`, `f-street-number` como
 * <input type="hidden"> para que el payload existente de /api/valuar
 * siga funcionando sin cambios. Suma `f-province`, `f-address`, `f-lat`,
 * `f-lng`.
 *
 * Uso:
 *   <AddressInput required />
 */
import { PROVINCIAS } from '../data/argentina-provinces'

interface Props {
  required?: boolean
}
const { required = false } = Astro.props
---

<div id="address-input" class="relative" data-verified="false">
  <!-- Provincia combobox (con type-to-filter) -->
  <div id="province-combo" class="mb-4 relative">
    <label class="text-xs font-semibold uppercase tracking-wider text-muted block mb-1.5">
      Provincia
    </label>
    <button
      id="province-trigger"
      type="button"
      class="w-full flex items-center gap-3 pl-3 pr-3 py-2.5 rounded-xl bg-bg border border-border text-text hover:border-accent/40 focus:outline-none focus:border-accent transition-colors"
    >
      <span class="flex-shrink-0 w-9 h-9 rounded-xl bg-accent/10 text-accent flex items-center justify-center">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="16" rx="2" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
      </span>
      <span id="province-label" class="flex-1 text-left text-muted truncate">
        Elegí una provincia…
      </span>
      <svg
        id="province-chevron"
        class="flex-shrink-0 w-4 h-4 text-muted transition-transform"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9" />
      </svg>
    </button>

    <div
      id="province-panel"
      class="hidden absolute z-40 left-0 right-0 mt-1 bg-elevated border border-border rounded-xl shadow-2xl overflow-hidden"
    >
      <div class="p-2 border-b border-border">
        <input
          id="province-search"
          type="text"
          autocomplete="off"
          placeholder="Buscar provincia…"
          class="w-full px-3 py-2 bg-bg rounded-lg border border-border text-sm text-text placeholder:text-muted/60 focus:outline-none focus:border-accent transition-colors"
        />
      </div>
      <ul
        id="province-list"
        role="listbox"
        class="max-h-64 overflow-y-auto"
      ></ul>
    </div>
  </div>

  <!-- Dirección (autocomplete Nominatim) -->
  <label class="text-xs font-semibold uppercase tracking-wider text-muted block mb-1.5">
    Dirección
  </label>

  <div class="relative">
    <input
      id="f-address-search"
      type="text"
      autocomplete="off"
      placeholder="Elegí provincia primero…"
      disabled
      required={required}
      class="w-full pl-10 pr-10 py-2.5 rounded-xl bg-bg border border-border text-text focus:outline-none focus:border-accent transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
    />
    <svg
      aria-hidden="true"
      class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted pointer-events-none"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.2"
    >
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
      <circle cx="12" cy="10" r="3" />
    </svg>

    <span
      id="f-address-status"
      class="absolute right-2 top-1/2 -translate-y-1/2 hidden flex items-center gap-1"
      aria-hidden="true"
    >
      <span
        id="f-address-spinner"
        class="hidden w-4 h-4 rounded-full border-2 border-muted/40 border-t-accent animate-spin"
      ></span>
      <svg
        id="f-address-check"
        class="hidden w-4 h-4 text-green-500"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
      >
        <polyline points="20 6 9 17 4 12" />
      </svg>
      <button
        id="f-address-clear"
        type="button"
        aria-label="Limpiar dirección y volver a editar"
        title="Limpiar"
        class="hidden w-7 h-7 rounded-full text-muted hover:text-red-500 hover:bg-red-500/10 active:scale-90 transition-all flex items-center justify-center"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </span>
  </div>

  <p id="f-address-hint" class="text-[11px] text-muted mt-1.5 leading-snug">
    Primero elegí la provincia, después tipeá la dirección.
  </p>

  <!-- Lista de sugerencias -->
  <ul
    id="f-address-suggestions"
    role="listbox"
    class="hidden absolute z-30 left-0 right-0 mt-1 max-h-72 overflow-y-auto bg-elevated border border-border rounded-xl shadow-2xl"
  ></ul>

  <!-- Hidden fields que consume el form / payload del wizard -->
  <input type="hidden" id="f-province" name="f-province" />
  <input type="hidden" id="f-location" name="f-location" />
  <input type="hidden" id="f-street" name="f-street" />
  <input type="hidden" id="f-street-number" name="f-street-number" />
  <input type="hidden" id="f-address" name="f-address" />
  <input type="hidden" id="f-lat" name="f-lat" />
  <input type="hidden" id="f-lng" name="f-lng" />
</div>

<script>
  import { searchAddresses, type AddressResult } from '../lib/address-search'
  import { PROVINCIAS } from '../data/argentina-provinces'

  const root = document.getElementById('address-input') as HTMLDivElement
  const search = document.getElementById('f-address-search') as HTMLInputElement
  const list = document.getElementById('f-address-suggestions') as HTMLUListElement
  const hint = document.getElementById('f-address-hint') as HTMLParagraphElement
  const status = document.getElementById('f-address-status') as HTMLSpanElement
  const spinner = document.getElementById('f-address-spinner') as HTMLSpanElement
  const check = document.getElementById('f-address-check') as HTMLElement
  const clearBtn = document.getElementById('f-address-clear') as HTMLButtonElement
  const fProvince = document.getElementById('f-province') as HTMLInputElement
  const fLocation = document.getElementById('f-location') as HTMLInputElement
  const fStreet = document.getElementById('f-street') as HTMLInputElement
  const fStreetNum = document.getElementById('f-street-number') as HTMLInputElement
  const fAddress = document.getElementById('f-address') as HTMLInputElement
  const fLat = document.getElementById('f-lat') as HTMLInputElement
  const fLng = document.getElementById('f-lng') as HTMLInputElement

  // Province combobox
  const provinceCombo = document.getElementById('province-combo') as HTMLDivElement
  const provinceTrigger = document.getElementById('province-trigger') as HTMLButtonElement
  const provincePanel = document.getElementById('province-panel') as HTMLDivElement
  const provinceSearch = document.getElementById('province-search') as HTMLInputElement
  const provinceList = document.getElementById('province-list') as HTMLUListElement
  const provinceLabel = document.getElementById('province-label') as HTMLSpanElement
  const provinceChevron = document.getElementById('province-chevron') as unknown as SVGElement

  let selectedProvince: string | null = null

  let debounce: number | undefined
  let activeController: AbortController | null = null

  function escapeHtml(s: string): string {
    const d = document.createElement('div')
    d.textContent = s
    return d.innerHTML
  }

  // ====== Province combobox ======

  function renderProvinceOptions(filter: string) {
    const norm = filter
      .toLowerCase()
      .normalize('NFD')
      .replace(/[̀-ͯ]/g, '')
      .trim()
    const items = norm
      ? PROVINCIAS.filter((p) => {
          const a = p.label.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '')
          const b = p.nominatim.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '')
          return a.includes(norm) || b.includes(norm)
        })
      : PROVINCIAS
    if (items.length === 0) {
      provinceList.innerHTML = `
        <li class="px-4 py-3 text-sm text-muted">Sin coincidencias.</li>
      `
      return
    }
    provinceList.innerHTML = items
      .map((p) => {
        const isSel = selectedProvince === p.nominatim
        return `
        <li role="option" data-value="${escapeHtml(p.nominatim)}" data-label="${escapeHtml(p.label)}"
            class="px-4 py-2.5 cursor-pointer transition-colors border-b border-border last:border-b-0 ${isSel ? 'bg-accent/10 text-accent font-semibold' : 'text-text hover:bg-accent/10'}">
          ${escapeHtml(p.label)}
        </li>`
      })
      .join('')
    provinceList.querySelectorAll<HTMLLIElement>('[data-value]').forEach((li) => {
      li.addEventListener('mousedown', (e) => {
        e.preventDefault()
        const value = li.dataset.value!
        const label = li.dataset.label!
        selectProvince(value, label)
      })
    })
  }

  function selectProvince(nominatim: string, label: string) {
    selectedProvince = nominatim
    fProvince.value = nominatim
    provinceLabel.textContent = label
    provinceLabel.classList.remove('text-muted')
    provinceLabel.classList.add('text-text', 'font-semibold')
    closeProvincePanel()

    // Habilitar el input de dirección y resetear estado previo.
    search.disabled = false
    search.placeholder = 'Empezá a tipear: Av. Callao 1240…'
    clearVerified()
    search.value = ''
    list.innerHTML = ''
    list.classList.add('hidden')
    hint.textContent = 'Elegí una de las sugerencias para verificar la ubicación.'
    hint.classList.remove('text-green-600')
    hint.classList.add('text-muted')
    setTimeout(() => search.focus(), 50)
  }

  function openProvincePanel() {
    provincePanel.classList.remove('hidden')
    provinceChevron.classList.add('rotate-180')
    provinceSearch.value = ''
    renderProvinceOptions('')
    setTimeout(() => provinceSearch.focus(), 30)
  }

  function closeProvincePanel() {
    provincePanel.classList.add('hidden')
    provinceChevron.classList.remove('rotate-180')
  }

  provinceTrigger.addEventListener('click', () => {
    if (provincePanel.classList.contains('hidden')) openProvincePanel()
    else closeProvincePanel()
  })
  provinceSearch.addEventListener('input', () => {
    renderProvinceOptions(provinceSearch.value)
  })
  provinceSearch.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeProvincePanel()
      provinceTrigger.focus()
    }
  })
  document.addEventListener('mousedown', (e) => {
    if (!provinceCombo.contains(e.target as Node)) closeProvincePanel()
  })

  // ====== Address autocomplete ======

  function setBusy(busy: boolean) {
    const verified = root.dataset.verified === 'true'
    status.classList.toggle('hidden', !busy && !verified)
    spinner.classList.toggle('hidden', !busy)
    if (busy) check.classList.add('hidden')
  }

  function formatAddressLine(r: AddressResult): string {
    if (r.street) {
      return r.houseNumber ? `${r.street} ${r.houseNumber}` : r.street
    }
    return r.displayName.split(',')[0]?.trim() || r.displayName
  }

  function formatBarrioLine(r: AddressResult): string {
    return r.city || ''
  }

  function setVerified(r: AddressResult) {
    root.dataset.verified = 'true'
    fAddress.value = r.displayName
    fLocation.value = [r.city, r.province].filter(Boolean).join(', ') || r.displayName
    fStreet.value = r.street ?? ''
    fStreetNum.value = r.houseNumber ?? ''
    fLat.value = String(r.lat)
    fLng.value = String(r.lng)
    if (r.province) fProvince.value = r.province
    search.value = formatAddressLine(r)
    // Una vez geolocalizado bloqueamos el input para que no se pueda
    // toquetear sin querer. El usuario tiene que apretar la X explícita
    // para volver a editar.
    search.readOnly = true
    search.classList.add('cursor-not-allowed', 'border-green-500/40')
    list.innerHTML = ''
    list.classList.add('hidden')
    status.classList.remove('hidden')
    spinner.classList.add('hidden')
    check.classList.remove('hidden')
    clearBtn.classList.remove('hidden')
    hint.textContent = '✓ Dirección verificada — tocá la cruz para editar'
    hint.classList.remove('text-muted')
    hint.classList.add('text-green-600')
    // OJO: NO disparamos el evento input acá. Hacerlo retriggerea el
    // listener de input que invalida la verificación al toque.
  }

  function clearVerified() {
    root.dataset.verified = 'false'
    fAddress.value = ''
    fLocation.value = ''
    fStreet.value = ''
    fStreetNum.value = ''
    fLat.value = ''
    fLng.value = ''
    check.classList.add('hidden')
    clearBtn.classList.add('hidden')
    status.classList.add('hidden')
    search.readOnly = false
    search.classList.remove('cursor-not-allowed', 'border-green-500/40')
    hint.textContent = 'Elegí una de las sugerencias para verificar la ubicación.'
    hint.classList.add('text-muted')
    hint.classList.remove('text-green-600')
  }

  // Click en la X → limpiar y volver a editar.
  clearBtn.addEventListener('click', () => {
    clearVerified()
    search.value = ''
    setTimeout(() => search.focus(), 30)
  })

  function renderSuggestions(items: AddressResult[]) {
    if (items.length === 0) {
      list.innerHTML = `
        <li class="px-4 py-3 text-sm text-muted">
          Sin coincidencias en ${escapeHtml(provinceLabel.textContent ?? 'esta provincia')}. Probá con otra forma — ej: "Av. Callao 1240".
        </li>
      `
      list.classList.remove('hidden')
      return
    }
    list.innerHTML = items
      .map((r, i) => {
        const main = escapeHtml(formatAddressLine(r))
        const sub = escapeHtml(formatBarrioLine(r))
        return `
        <li role="option" data-idx="${i}"
            class="group px-3 py-2.5 cursor-pointer hover:bg-accent/10 transition-colors border-b border-border last:border-b-0">
          <div class="flex items-center gap-3">
            <span class="flex-shrink-0 w-9 h-9 rounded-xl bg-accent/10 text-accent flex items-center justify-center group-hover:bg-accent group-hover:text-white transition-colors">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </span>
            <div class="min-w-0 flex-1">
              <div class="text-sm font-semibold text-text leading-snug truncate">${main}</div>
              ${sub ? `<div class="text-xs text-muted leading-snug truncate mt-0.5">${sub}</div>` : ''}
            </div>
            <svg class="flex-shrink-0 w-4 h-4 text-muted/40 group-hover:text-accent transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </div>
        </li>`
      })
      .join('')
    list.classList.remove('hidden')
    list.querySelectorAll<HTMLLIElement>('[data-idx]').forEach((li) => {
      li.addEventListener('mousedown', (e) => {
        e.preventDefault()
        const idx = Number(li.dataset.idx)
        const item = items[idx]
        if (item) setVerified(item)
      })
    })
  }

  search.addEventListener('input', () => {
    if (search.disabled) return
    if (root.dataset.verified === 'true') clearVerified()

    if (debounce) window.clearTimeout(debounce)
    if (activeController) activeController.abort()

    const q = search.value.trim()
    if (q.length < 3) {
      list.classList.add('hidden')
      setBusy(false)
      return
    }

    setBusy(true)
    debounce = window.setTimeout(async () => {
      activeController = new AbortController()
      try {
        const items = await searchAddresses(q, activeController.signal, {
          province: selectedProvince ?? undefined,
        })
        renderSuggestions(items)
      } catch {
        // ignore
      } finally {
        setBusy(false)
      }
    }, 400)
  })

  search.addEventListener('blur', () => {
    setTimeout(() => list.classList.add('hidden'), 150)
  })

  search.addEventListener('focus', () => {
    // No reabrimos la lista si está bloqueado o ya hay una dirección verificada.
    if (search.readOnly || root.dataset.verified === 'true') return
    if (list.children.length > 0) {
      list.classList.remove('hidden')
    }
  })

  // Init: precargar la lista de provincias en el panel.
  renderProvinceOptions('')
</script>
