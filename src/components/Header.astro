---
import { NAV, NAV_CTA, LOGOS, CONTACT } from '../data/site'
import ThemeSwitcher from './ThemeSwitcher.astro'
const path = Astro.url.pathname
---

<header class="sticky top-12 lg:top-14 z-40 transition-all duration-300 border-b border-transparent">
  <div class="absolute inset-0 -z-10 backdrop-blur-xl bg-bg/70 opacity-0 transition-opacity duration-300" data-header-bg></div>

  <div class="container-app flex items-center justify-between h-16 lg:h-20">
    <a href="/" class="flex items-center gap-3 group" aria-label="Coldwell Banker Beyker — Inicio">
      <img
        src={LOGOS.primary}
        alt="Coldwell Banker Beyker"
        class="h-8 lg:h-10 w-auto transition-transform duration-300 group-hover:scale-105"
        width="180"
        height="40"
      />
    </a>

    <nav class="hidden lg:flex items-center gap-1">
      {NAV.map((item) => {
        const active = path === item.href || (item.href !== '/' && path.startsWith(item.href))
        return (
          <a
            href={item.href}
            class:list={[
              'relative px-3.5 py-2 rounded-full text-sm font-medium transition-all duration-200',
              active
                ? 'text-text bg-elevated/80'
                : 'text-muted hover:text-text hover:bg-elevated/50',
            ]}
          >
            {item.label}
            {active && (
              <span class="absolute -bottom-px left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-accent"></span>
            )}
          </a>
        )
      })}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={NAV_CTA.href}
        class="hidden sm:inline-flex btn-gold text-sm px-4 py-2"
      >
        {NAV_CTA.label}
      </a>
      <a
        href={CONTACT.whatsapp_link}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp"
        title="WhatsApp"
        class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-text/70 hover:text-[#25D366] hover:border-[#25D366]/40 hover:bg-[#25D366]/5 transition-all duration-200"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
        </svg>
      </a>
      <ThemeSwitcher />
      <button
        id="menu-toggle"
        type="button"
        class="lg:hidden w-10 h-10 rounded-full border border-border flex items-center justify-center hover:bg-elevated transition-colors"
        aria-label="Abrir menú"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden border-t border-border bg-bg/95 backdrop-blur-xl">
    <nav class="container-app py-4 flex flex-col gap-1">
      {NAV.map((item) => (
        <a
          href={item.href}
          class="px-4 py-3 rounded-xl text-sm font-medium text-text hover:bg-elevated transition-all"
        >
          {item.label}
        </a>
      ))}
      <a href={NAV_CTA.href} class="mt-2 px-4 py-3 rounded-xl text-sm font-semibold text-accent hover:bg-elevated transition-all">
        {NAV_CTA.label} →
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'))

  // Background del header se hace visible al scrollear.
  const bg = document.querySelector('[data-header-bg]') as HTMLElement | null
  const updateBg = () => {
    if (!bg) return
    bg.style.opacity = window.scrollY > 12 ? '1' : '0'
  }
  updateBg()
  window.addEventListener('scroll', updateBg, { passive: true })
</script>
