---
import { formatPriceUSD, type Property } from '../data/properties'
interface Props { property: Property }
const { property } = Astro.props
const opLabel = property.operacion
  ? property.operacion[0].toUpperCase() + property.operacion.slice(1)
  : 'Consultar'
const detailHref = property.detailUrl || '#'
---

<article class="property-card group reveal">
  <a href={detailHref} target="_blank" rel="noopener" class="block relative aspect-[4/3] overflow-hidden bg-elevated-hi">
    {property.image ? (
      <img
        src={property.image}
        alt={property.title}
        loading="lazy"
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center text-muted">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <polyline points="21 15 16 10 5 21" />
        </svg>
      </div>
    )}

    <!-- Overlay gradient para legibilidad -->
    <div class="absolute inset-0 bg-gradient-to-t from-bg/90 via-bg/10 to-transparent opacity-90 group-hover:opacity-100 transition-opacity"></div>

    <!-- Badges arriba -->
    <div class="absolute top-3 left-3 right-3 flex items-start justify-between gap-2">
      <div class="flex flex-wrap gap-2">
        <span class="pill-accent">{opLabel}</span>
        {property.type && <span class="pill">{property.type}</span>}
      </div>
      {property.reference && (
        <span class="pill text-[10px] opacity-70">{property.reference}</span>
      )}
    </div>

    <!-- Precio overlay abajo -->
    <div class="absolute bottom-3 left-4 right-4">
      <div class="text-[10px] uppercase tracking-wider text-muted mb-0.5">Precio de {property.operacion || 'venta'}</div>
      <div class="text-2xl font-display font-bold text-text leading-none">
        {formatPriceUSD(property.priceValue, property.priceCurrency)}
      </div>
    </div>
  </a>

  <div class="p-5 flex-1 flex flex-col gap-3 min-w-0">
    <div class="min-w-0">
      <h3 class="text-base lg:text-lg font-bold text-text leading-snug line-clamp-2 group-hover:text-accent transition-colors">
        {property.title || 'Propiedad'}
      </h3>
      {property.location && (
        <p class="text-sm text-muted truncate mt-1 flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          {property.location}
        </p>
      )}
    </div>

    <div class="flex items-center gap-4 text-sm text-text/70 pt-3 mt-auto border-t border-border flex-wrap">
      {property.bedrooms != null && (
        <span class="flex items-center gap-1.5" title="Dormitorios">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 4v16M22 4v16M2 12h20M6 16h2M16 16h2" />
          </svg>
          {property.bedrooms}
        </span>
      )}
      {property.bathrooms != null && (
        <span class="flex items-center gap-1.5" title="Baños">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 6V4a2 2 0 012-2h2a2 2 0 012 2v2M3 10h18M5 10v8a3 3 0 003 3h8a3 3 0 003-3v-8" />
          </svg>
          {property.bathrooms}
        </span>
      )}
      {property.surfaceM2 != null && (
        <span class="flex items-center gap-1.5" title="Superficie">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="18" height="18" rx="2" />
          </svg>
          {property.surfaceM2} m²
        </span>
      )}
      <a
        href={detailHref}
        target="_blank"
        rel="noopener"
        class="ml-auto text-xs font-semibold text-accent hover:text-accent-hover transition-colors flex items-center gap-1"
      >
        Ver ficha
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </div>
</article>
